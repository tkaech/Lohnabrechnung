<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Payroll.Desktop.Controls"
    xmlns:formatting="clr-namespace:Payroll.Desktop.Formatting">
  <Styles.Resources>
    <formatting:ChfAmountConverter x:Key="ChfAmountConverter" />

    <FontFamily x:Key="Theme.FontFamily">Segoe UI, DejaVu Sans, Arial</FontFamily>
    <x:Double x:Key="Theme.FontSize.Body">13</x:Double>
    <x:Double x:Key="Theme.FontSize.Caption">12</x:Double>
    <x:Double x:Key="Theme.FontSize.Section">16</x:Double>
    <x:Double x:Key="Theme.FontSize.Page">18</x:Double>
    <x:Double x:Key="Theme.FontSize.AppTitle">24</x:Double>
    <x:Double x:Key="Theme.Layout.SectionSpacing">12</x:Double>
    <Thickness x:Key="Theme.Spacing.CardPadding">16</Thickness>
    <Thickness x:Key="Theme.Layout.PagePadding">20</Thickness>
    <Thickness x:Key="Theme.Layout.PanelPadding">12</Thickness>
    <CornerRadius x:Key="Theme.Layout.PanelCornerRadius">8</CornerRadius>
    <x:Double x:Key="Theme.Layout.TableCellVerticalPadding">6</x:Double>
    <Thickness x:Key="Theme.Layout.TableCellPadding">8,6</Thickness>
    <Thickness x:Key="Theme.Layout.SectionSpacing.TopMargin">0,12,0,0</Thickness>
    <Thickness x:Key="Theme.Selection.EmployeeHighlightInset">2</Thickness>

    <SolidColorBrush x:Key="Theme.Color.AppBackground">#FFF5F7FA</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.Surface">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.SurfaceMuted">#FFF8FAFC</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.SurfaceSubtle">#FFEFF4F8</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.Border">#FFD7DFEA</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.BorderSoft">#FFE2E8F0</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.TextPrimary">#FF1A2530</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.TextMuted">#FF5F6B7A</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.TextInverse">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.TextStatus">#FF304255</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.PayrollStatus.Finalized">#FF1F7A3D</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.PayrollStatus.Open">#FFC53B3B</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.PayrollStatus.OpenWithData">#FFCC7A00</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.PayrollStatus.Cancelled">#FF6B5A2A</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.Brand">#FF14324A</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.BrandSoft">#FFD1DCE7</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.Danger">#FFC95F36</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.WarningSurface">#FFFFF1E6</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.WarningText">#FF6B4A1F</SolidColorBrush>
    <SolidColorBrush x:Key="Theme.Color.ChipSurface">#FFE6EEF5</SolidColorBrush>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.AppBackground}" />
    <Setter Property="FontFamily" Value="{DynamicResource Theme.FontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource Theme.FontSize.Body}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextPrimary}" />
  </Style>

  <Style Selector="controls|AppSectionCard">
    <Setter Property="Template">
      <ControlTemplate>
        <Border
            Background="{DynamicResource Theme.Color.Surface}"
            BorderBrush="{DynamicResource Theme.Color.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}"
            Padding="{DynamicResource Theme.Layout.PanelPadding}">
          <Grid RowDefinitions="Auto,*">
            <TextBlock
                Classes="section-title"
                Text="{TemplateBinding Header}" />
            <ContentPresenter
                Grid.Row="1"
                Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}"
                Content="{TemplateBinding Content}" />
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="TextBlock.section-caption">
    <Setter Property="FontSize" Value="{DynamicResource Theme.FontSize.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextMuted}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.app-title">
    <Setter Property="FontSize" Value="{DynamicResource Theme.FontSize.AppTitle}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextInverse}" />
  </Style>

  <Style Selector="TextBlock.app-subtitle">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.BrandSoft}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="{DynamicResource Theme.FontSize.Page}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="{DynamicResource Theme.FontSize.Section}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.body-muted">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextMuted}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.status-text">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextStatus}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.payroll-status">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextStatus}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.payroll-status-finalized">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.PayrollStatus.Finalized}" />
  </Style>

  <Style Selector="TextBlock.payroll-status-open">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.PayrollStatus.Open}" />
  </Style>

  <Style Selector="TextBlock.payroll-status-open-with-data">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.PayrollStatus.OpenWithData}" />
  </Style>

  <Style Selector="TextBlock.payroll-status-cancelled">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.PayrollStatus.Cancelled}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="10,5" />
  </Style>

  <Style Selector="ToggleButton">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="10,5" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="10,5" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="MinHeight" Value="32" />
  </Style>

  <Style Selector="DatePicker">
    <Setter Property="MinHeight" Value="32" />
  </Style>

  <Style Selector="AutoCompleteBox">
    <Setter Property="MinHeight" Value="32" />
  </Style>

  <Style Selector="Border.surface-panel">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Theme.Layout.PanelCornerRadius}" />
  </Style>

  <Style Selector="Border.subtle-panel">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.SurfaceMuted}" />
  </Style>

  <Style Selector="Border.emphasis-panel">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.SurfaceSubtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.BorderSoft}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.warning-panel">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.WarningSurface}" />
  </Style>

  <Style Selector="Border.chip-panel">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.ChipSurface}" />
  </Style>

  <Style Selector="ListBox.employee-selection-list ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="{DynamicResource Theme.Selection.EmployeeHighlightInset}" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="ListBox.employee-selection-list ListBoxItem:selected">
    <Setter Property="Background" Value="#FFEAF3F9" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.employee-selection-list ListBoxItem:pointerover">
    <Setter Property="Background" Value="#FFF4F8FB" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.employee-selection-list">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="ListBox.main-navigation-list">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="ListBox.main-navigation-list ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="ListBox.table-list">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem">
    <Setter Property="Background" Value="#FFFFFFFF" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem:selected">
    <Setter Property="Background" Value="#FFEAF3F9" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem:pointerover">
    <Setter Property="Background" Value="#FFF4F8FB" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem:selected:pointerover">
    <Setter Property="Background" Value="#FFEAF3F9" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem:selected:pressed">
    <Setter Property="Background" Value="#FFEAF3F9" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem:selected:focus">
    <Setter Property="Background" Value="#FFEAF3F9" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem:selected:focus-within">
    <Setter Property="Background" Value="#FFEAF3F9" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem:selected:pointerover:pressed">
    <Setter Property="Background" Value="#FFEAF3F9" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem:selected:pointerover:focus">
    <Setter Property="Background" Value="#FFEAF3F9" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.table-list ListBoxItem:selected:pointerover:focus-within">
    <Setter Property="Background" Value="#FFEAF3F9" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="TextBox.month-picker-input">
    <Setter Property="MinWidth" Value="118" />
    <Setter Property="Padding" Value="10,5,36,5" />
  </Style>

  <Style Selector="TextBox.date-picker-input">
    <Setter Property="MinWidth" Value="118" />
    <Setter Property="Padding" Value="10,5,36,5" />
  </Style>

  <Style Selector="Button.date-picker-icon-button">
    <Setter Property="MinWidth" Value="30" />
    <Setter Property="Width" Value="30" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="-30,0,0,0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextMuted}" />
  </Style>

  <Style Selector="Border.month-picker-popup">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.BorderSoft}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Theme.Layout.PanelCornerRadius}" />
    <Setter Property="Padding" Value="{DynamicResource Theme.Layout.PanelPadding}" />
  </Style>

  <Style Selector="TextBlock.month-picker-year">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextPrimary}" />
  </Style>

  <Style Selector="Button.month-picker-nav-button">
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="Width" Value="32" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.month-picker-month-button">
    <Setter Property="MinWidth" Value="72" />
    <Setter Property="Margin" Value="2" />
    <Setter Property="Padding" Value="8,5" />
  </Style>

  <Style Selector="Button.month-picker-month-button.selected">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.Brand}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextInverse}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.Brand}" />
  </Style>

  <Style Selector="TextBlock.date-picker-weekday">
    <Setter Property="FontSize" Value="{DynamicResource Theme.FontSize.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextMuted}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.date-picker-day-button">
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="Width" Value="32" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Margin" Value="1" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.date-picker-day-button.muted">
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextMuted}" />
  </Style>

  <Style Selector="Button.date-picker-day-button.today">
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.Brand}" />
  </Style>

  <Style Selector="Button.date-picker-day-button.selected">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.Brand}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextInverse}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.Brand}" />
  </Style>

  <Style Selector="Button.date-picker-action-button">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="Margin" Value="0,0,6,0" />
  </Style>

  <Style Selector="Button.nav-active">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.Brand}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextInverse}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.Brand}" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="8,3" />
  </Style>

  <Style Selector="Button.nav-placeholder">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.SurfaceMuted}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextMuted}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.Border}" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="8,3" />
  </Style>

  <Style Selector="Button.primary-action">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.Brand}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextInverse}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.Brand}" />
  </Style>

  <Style Selector="Button.danger-action">
    <Setter Property="Background" Value="{DynamicResource Theme.Color.Danger}" />
    <Setter Property="Foreground" Value="{DynamicResource Theme.Color.TextInverse}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Color.Danger}" />
  </Style>
</Styles>
