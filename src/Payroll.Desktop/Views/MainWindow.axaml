<Window
    x:Class="Payroll.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Payroll.Desktop.Controls"
    Title="{Binding Title}"
    Width="1460"
    Height="920"
    MinWidth="1200"
    MinHeight="760"
    Background="#FFF5F7FA">
  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20">
    <Border
        Grid.Row="0"
        Padding="18"
        Background="#FF14324A"
        CornerRadius="14"
        Margin="0,0,0,16">
      <StackPanel Spacing="6">
        <TextBlock FontSize="24" FontWeight="Bold" Foreground="White" Text="PayrollApp" />
        <TextBlock Foreground="#FFD1DCE7" Text="Monatszentrierte Arbeitsoberflaeche fuer Zeit- und Spesenerfassung mit separatem Mitarbeitendenbereich." />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Background="#FFFFFFFF" BorderBrush="#FFD7DFEA" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,16">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Button Classes="nav-active" Content="Zeit- und Spesenerfassung" IsVisible="{Binding IsTimeAndExpensesWorkspace}" />
        <Button Classes="nav-placeholder" Content="Zeit- und Spesenerfassung" Command="{Binding ShowTimeAndExpensesCommand}" IsVisible="{Binding IsEmployeeWorkspace}" />
        <Button Classes="nav-placeholder" Content="Zeit- und Spesenerfassung" Command="{Binding ShowTimeAndExpensesCommand}" IsVisible="{Binding IsSettingsWorkspace}" />
        <Button Classes="nav-active" Content="Mitarbeitende" IsVisible="{Binding IsEmployeeWorkspace}" />
        <Button Classes="nav-placeholder" Content="Mitarbeitende" Command="{Binding ShowEmployeesCommand}" IsVisible="{Binding IsTimeAndExpensesWorkspace}" />
        <Button Classes="nav-placeholder" Content="Mitarbeitende" Command="{Binding ShowEmployeesCommand}" IsVisible="{Binding IsSettingsWorkspace}" />
        <Button Classes="nav-placeholder" Content="Lohnlaeufe" IsEnabled="False" />
        <Button Classes="nav-placeholder" Content="AHV / Abzuege" IsEnabled="False" />
        <Button Classes="nav-placeholder" Content="Quellensteuer" IsEnabled="False" />
        <Button Classes="nav-placeholder" Content="Reporting" IsEnabled="False" />
        <Button Classes="nav-active" Content="Einstellungen" IsVisible="{Binding IsSettingsWorkspace}" />
        <Button Classes="nav-placeholder" Content="Einstellungen" Command="{Binding ShowSettingsCommand}" IsVisible="{Binding IsTimeAndExpensesWorkspace}" />
        <Button Classes="nav-placeholder" Content="Einstellungen" Command="{Binding ShowSettingsCommand}" IsVisible="{Binding IsEmployeeWorkspace}" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="250,360,*" MinHeight="0">
      <controls:AppSectionCard Grid.Column="0" Header="Bereiche" Margin="0,0,8,0">
        <StackPanel Spacing="10">
          <TextBlock Classes="section-caption" Text="Erfassung zuerst. Personendaten bleiben separat, damit die Monatserfassung schlank und fokussiert bleibt." TextWrapping="Wrap" />
          <Button Classes="nav-active" Content="Zeit- und Spesenerfassung" IsVisible="{Binding IsTimeAndExpensesWorkspace}" />
          <Button Classes="nav-placeholder" Content="Zeit- und Spesenerfassung" Command="{Binding ShowTimeAndExpensesCommand}" IsVisible="{Binding IsEmployeeWorkspace}" />
          <Button Classes="nav-placeholder" Content="Zeit- und Spesenerfassung" Command="{Binding ShowTimeAndExpensesCommand}" IsVisible="{Binding IsSettingsWorkspace}" />
          <Button Classes="nav-active" Content="Mitarbeitende" IsVisible="{Binding IsEmployeeWorkspace}" />
          <Button Classes="nav-placeholder" Content="Mitarbeitende" Command="{Binding ShowEmployeesCommand}" IsVisible="{Binding IsTimeAndExpensesWorkspace}" />
          <Button Classes="nav-placeholder" Content="Mitarbeitende" Command="{Binding ShowEmployeesCommand}" IsVisible="{Binding IsSettingsWorkspace}" />
          <Button Classes="nav-placeholder" Content="Lohnlaeufe (Platzhalter)" IsEnabled="False" />
          <Button Classes="nav-placeholder" Content="AHV / Abzuege (Platzhalter)" IsEnabled="False" />
          <Button Classes="nav-placeholder" Content="Quellensteuer (Platzhalter)" IsEnabled="False" />
          <Button Classes="nav-placeholder" Content="Reporting (Platzhalter)" IsEnabled="False" />
          <Button Classes="nav-active" Content="Einstellungen" IsVisible="{Binding IsSettingsWorkspace}" />
          <Button Classes="nav-placeholder" Content="Einstellungen" Command="{Binding ShowSettingsCommand}" IsVisible="{Binding IsTimeAndExpensesWorkspace}" />
          <Button Classes="nav-placeholder" Content="Einstellungen" Command="{Binding ShowSettingsCommand}" IsVisible="{Binding IsEmployeeWorkspace}" />
        </StackPanel>
      </controls:AppSectionCard>

      <controls:AppSectionCard Grid.Column="1" Header="Mitarbeitende" Margin="8,0">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" MinHeight="0">
          <Border Grid.Row="0" Background="#FFF8FAFC" CornerRadius="8" Padding="12" IsVisible="{Binding ShowTimeAndExpensesWorkspace}">
            <StackPanel Spacing="8" DataContext="{Binding MonthlyRecord}">
              <TextBlock FontSize="16" FontWeight="SemiBold" Text="Abrechnungsmonat" />
              <TextBlock Foreground="#FF5F6B7A" Text="Monat waehlen. Der Monatskontext wird anschliessend beim Mitarbeitendenwechsel automatisch geladen." TextWrapping="Wrap" />
              <DatePicker SelectedDate="{Binding SelectedMonth, Mode=TwoWay}" />
            </StackPanel>
          </Border>

          <Border Grid.Row="0" Background="#FFF8FAFC" CornerRadius="8" Padding="12" IsVisible="{Binding ShowEmployeeWorkspace}">
            <TextBlock Foreground="#FF5F6B7A" Text="Stammdaten werden separat gepflegt. Die gleiche Mitarbeitendenliste bleibt fuer beide Arbeitsbereiche erhalten." TextWrapping="Wrap" />
          </Border>

          <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
            <TextBox
                IsEnabled="{Binding CanSearchEmployees}"
                Watermark="Suche nach Name, Personalnummer, Ort oder E-Mail"
                Text="{Binding SearchText, Mode=TwoWay}" />
            <ComboBox
                Grid.Column="1"
                Width="120"
                Margin="8,0,0,0"
                IsEnabled="{Binding CanSearchEmployees}"
                ItemsSource="{Binding ActivityFilters}"
                SelectedItem="{Binding SelectedActivityFilter, Mode=TwoWay}" />
            <Button
                Grid.Column="2"
                Margin="8,0,0,0"
                Command="{Binding SearchCommand}"
                Content="Suchen" />
          </Grid>

          <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Command="{Binding RefreshCommand}" Content="Aktualisieren" />
          </StackPanel>

          <TextBlock Grid.Row="3" Margin="0,12,0,0" Foreground="#FF5F6B7A" Text="{Binding EmployeeCountSummary}" />

          <ListBox
              Grid.Row="4"
              MinHeight="0"
              Margin="0,12,0,0"
              IsEnabled="{Binding CanSelectEmployees}"
              ItemsSource="{Binding Employees}"
              SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="10" Margin="0,0,0,8" Background="#FFF8FAFC" CornerRadius="8">
                  <StackPanel Spacing="3">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock FontWeight="SemiBold" Text="{Binding FullName}" />
                      <Border Grid.Column="1" Margin="8,0,0,0" Background="#FFE6EEF5" CornerRadius="999" Padding="8,2">
                        <TextBlock Classes="section-caption" Text="{Binding StatusSummary}" />
                      </Border>
                    </Grid>
                    <TextBlock Classes="section-caption" Text="{Binding PersonnelNumber}" />
                    <TextBlock Foreground="#FF4A5868" Text="{Binding ContactSummary}" TextWrapping="Wrap" />
                    <TextBlock Foreground="#FF4A5868" Text="{Binding ContractSummary}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </controls:AppSectionCard>

      <controls:AppSectionCard Grid.Column="2" Header="Arbeitsbereich" Margin="8,0,0,0">
        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" MinHeight="0">
          <Border Background="#FFF8FAFC" CornerRadius="8" Padding="12">
            <Grid>
              <StackPanel Spacing="4" IsVisible="{Binding ShowTimeAndExpensesWorkspace}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Zeit- und Spesenerfassung" />
                <TextBlock Foreground="#FF5F6B7A" Text="Monat zuerst waehlen, danach Mitarbeitenden in der Liste selektieren und rechts Zeiten oder Spesen erfassen. Personendaten stoeren diesen Arbeitsfluss nicht mehr." TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Spacing="4" IsVisible="{Binding ShowEmployeeWorkspace}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding FormTitle}" />
                <TextBlock Foreground="#FF5F6B7A" Text="{Binding FormDescription}" TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Spacing="4" IsVisible="{Binding ShowSettingsWorkspace}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Einstellungen" />
                <TextBlock Foreground="#FF5F6B7A" Text="Zentrale Pflege der lohnrelevanten Zuschlagssaetze. Diese Werte gehoeren nicht mehr in den Personenstamm." TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1" Margin="0,12,0,0" IsVisible="{Binding ShowTimeAndExpensesWorkspace}">
            <Grid RowDefinitions="Auto,*" MinHeight="0" DataContext="{Binding MonthlyRecord}">
              <Border Background="#FFF8FAFC" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                  <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding ContextTitle}" />
                  <TextBlock Foreground="#FF5F6B7A" Text="{Binding ContextDescription}" TextWrapping="Wrap" />
                  <TextBlock Classes="section-caption" Text="{Binding StatusSummary}" />
                  <TextBlock Classes="section-caption" Text="{Binding ContractSummary}" TextWrapping="Wrap" />
                  <TextBlock Classes="section-caption" Text="{Binding TotalsSummary}" TextWrapping="Wrap" />
                  <TextBlock Classes="section-caption" Text="{Binding ActionMessage}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <TabControl Grid.Row="1" Margin="0,12,0,0">
                <TabItem Header="Zeiten">
                  <ScrollViewer MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" Margin="0,10,0,0">
                      <Grid ColumnDefinitions="*,*,*,*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Datum" />
                          <TextBox Text="{Binding TimeDate, Mode=TwoWay}" Watermark="YYYY-MM-DD" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Arbeitsstunden" />
                          <TextBox Text="{Binding HoursWorked, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Nachtstunden" />
                          <TextBox Text="{Binding NightHours, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Sonntagsstunden" />
                          <TextBox Text="{Binding SundayHours, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Spacing="4">
                          <TextBlock Classes="section-caption" Text="Feiertagsstunden" />
                          <TextBox Text="{Binding HolidayHours, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="5" Spacing="4" Margin="0,10,0,0">
                          <TextBlock Classes="section-caption" Text="Bemerkung" />
                          <TextBox Text="{Binding TimeNote, Mode=TwoWay}" />
                        </StackPanel>
                      </Grid>

                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding NewTimeEntryCommand}" Content="Neu" />
                        <Button Command="{Binding SaveTimeEntryCommand}" Content="Zeiteintrag speichern" />
                        <Button Command="{Binding DeleteTimeEntryCommand}" Content="Zeiteintrag loeschen" />
                      </StackPanel>

                      <TextBlock Classes="section-caption" Text="Tagesliste" />
                      <ListBox ItemsSource="{Binding TimeEntries}" SelectedItem="{Binding SelectedTimeEntry, Mode=TwoWay}" MinHeight="240">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Border Padding="10" Margin="0,0,0,8" Background="#FFF8FAFC" CornerRadius="8">
                              <StackPanel Spacing="3">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Summary}" />
                                <TextBlock Classes="section-caption" Text="{Binding Note}" TextWrapping="Wrap" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

                <TabItem Header="Spesen">
                  <ScrollViewer MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" Margin="0,10,0,0">
                      <TextBlock Foreground="#FF5F6B7A" Text="Erfasst wird nur das Monatstotal fuer Diverse Spesen." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Abrechnungsmonat" />
                          <TextBox Text="{Binding ExpensePayrollMonth}" IsReadOnly="True" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Datum" />
                          <TextBox Text="{Binding ExpenseDate, Mode=TwoWay}" Watermark="YYYY-MM-DD" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Betrag CHF" />
                          <TextBox Text="{Binding ExpenseAmount, Mode=TwoWay}" />
                        </StackPanel>
                      </Grid>

                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding NewExpenseEntryCommand}" Content="Neu" />
                        <Button Command="{Binding SaveExpenseEntryCommand}" Content="Spese speichern" />
                        <Button Command="{Binding DeleteExpenseEntryCommand}" Content="Spese loeschen" />
                      </StackPanel>

                      <TextBlock Classes="section-caption" Text="Spesenliste" />
                      <ListBox ItemsSource="{Binding ExpenseEntries}" SelectedItem="{Binding SelectedExpenseEntry, Mode=TwoWay}" MinHeight="220">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Border Padding="10" Margin="0,0,0,8" Background="#FFF8FAFC" CornerRadius="8">
                              <StackPanel Spacing="3">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Summary}" />
                                <TextBlock Classes="section-caption" Text="Diverse Spesen" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>

                      <TextBlock Classes="section-caption" Text="Fahrzeugentschaedigung" />
                      <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Datum" />
                          <TextBox Text="{Binding VehicleCompensationDate, Mode=TwoWay}" Watermark="YYYY-MM-DD" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Betrag CHF" />
                          <TextBox Text="{Binding VehicleCompensationAmount, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                          <TextBlock Classes="section-caption" Text="Beschreibung / Referenz" />
                          <TextBox Text="{Binding VehicleCompensationDescription, Mode=TwoWay}" />
                        </StackPanel>
                      </Grid>

                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding NewVehicleCompensationCommand}" Content="Neu" />
                        <Button Command="{Binding SaveVehicleCompensationCommand}" Content="Fahrzeugentschaedigung speichern" />
                        <Button Command="{Binding DeleteVehicleCompensationCommand}" Content="Fahrzeugentschaedigung loeschen" />
                      </StackPanel>

                      <ListBox ItemsSource="{Binding VehicleCompensations}" SelectedItem="{Binding SelectedVehicleCompensation, Mode=TwoWay}" MinHeight="120">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Border Padding="10" Margin="0,0,0,8" Background="#FFF8FAFC" CornerRadius="8">
                              <StackPanel Spacing="3">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Summary}" />
                                <TextBlock Classes="section-caption" Text="{Binding Description}" TextWrapping="Wrap" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

                <TabItem Header="Monatsvorschau">
                  <ScrollViewer MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10" Margin="0,10,0,0">
                      <Border Background="#FFF8FAFC" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="6">
                          <TextBlock FontWeight="SemiBold" Text="Verdichtete Monatsansicht" />
                          <TextBlock Text="{Binding PreviewSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                      <Border Background="#FFF8FAFC" CornerRadius="8" Padding="12">
                        <TextBlock Text="{Binding PreviewTotals}" TextWrapping="Wrap" />
                      </Border>
                      <Border Background="#FFF8FAFC" CornerRadius="8" Padding="12">
                        <TextBlock Text="{Binding PreviewEntryCounts}" TextWrapping="Wrap" />
                      </Border>
                      <TextBlock Classes="section-caption" Text="Monatseintraege" />
                      <Border Background="#FFF8FAFC" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="10">
                          <Grid ColumnDefinitions="110,140,120,140,*">
                            <TextBlock FontWeight="SemiBold" Text="Monat" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Datum" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Typ" />
                            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Stunden / Betrag" />
                            <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Details" />
                          </Grid>
                          <ItemsControl ItemsSource="{Binding PreviewRows}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Padding="8,6" Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="0,0,0,1">
                                  <Grid ColumnDefinitions="110,140,120,140,*">
                                    <TextBlock Text="{Binding MonthLabel}" />
                                    <TextBlock Grid.Column="1" Text="{Binding EntryDateLabel}" />
                                    <TextBlock Grid.Column="2" Text="{Binding EntryType}" />
                                    <TextBlock Grid.Column="3" Text="{Binding QuantityOrAmount}" />
                                    <TextBlock Grid.Column="4" Text="{Binding Details}" TextWrapping="Wrap" />
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                      <TextBlock Classes="section-caption" Text="Hinweise" />
                      <ItemsControl ItemsSource="{Binding PreviewNotes}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="10" Background="#FFF8FAFC" CornerRadius="8">
                              <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>
              </TabControl>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1" Margin="0,12,0,0" MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" IsVisible="{Binding ShowEmployeeWorkspace}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*">
              <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Classes="section-caption" Text="Stammdaten" />

              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Personalnummer" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding PersonnelNumber, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Vorname" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding FirstName, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="4" Margin="0,10,0,0">
                <TextBlock Classes="section-caption" Text="Nachname" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding LastName, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Geburtsdatum" />
                <DatePicker IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding BirthDate, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Eintrittsdatum" />
                <DatePicker IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding EntryDate, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="4" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Austrittsdatum" />
                <DatePicker IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding ExitDate, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="4" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Status" />
                <CheckBox IsChecked="{Binding IsActiveEmployee, Mode=TwoWay}" IsEnabled="{Binding CanEditFields}" Content="Aktiv" />
              </StackPanel>

              <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Classes="section-caption" Margin="0,8,0,0" Text="Adresse und Kontakt" />

              <StackPanel Grid.Row="6" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Strasse" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Street, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="6" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Hausnummer" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding HouseNumber, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Spacing="4" Margin="0,10,0,0">
                <TextBlock Classes="section-caption" Text="Adresszusatz" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding AddressLine2, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="8" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Postleitzahl" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding PostalCode, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="8" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Ort" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding City, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="9" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Land" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Country, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="9" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Wohnsitzland" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding ResidenceCountry, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="10" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Telefon" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding PhoneNumber, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="10" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="E-Mail" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Email, Mode=TwoWay}" />
              </StackPanel>

              <TextBlock Grid.Row="11" Grid.ColumnSpan="2" Classes="section-caption" Margin="0,8,0,0" Text="Payroll-relevante Stammdaten" />

              <StackPanel Grid.Row="12" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Nationalitaet" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Nationality, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="12" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Bewilligung" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding PermitCode, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="13" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Steuerstatus" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding TaxStatus, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="13" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Quellensteuerpflicht" />
                <ComboBox IsEnabled="{Binding CanEditFields}" ItemsSource="{Binding WithholdingTaxOptions}" SelectedItem="{Binding SelectedWithholdingTaxOption, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="14" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="AHV-Nummer" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding AhvNumber, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="14" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="IBAN" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Iban, Mode=TwoWay}" />
              </StackPanel>

              <TextBlock Grid.Row="15" Grid.ColumnSpan="2" Classes="section-caption" Margin="0,8,0,0" Text="Vertragsdaten" />

              <StackPanel Grid.Row="16" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Gueltig ab" />
                <DatePicker IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding ContractValidFrom, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="16" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Gueltig bis" />
                <DatePicker IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding ContractValidTo, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="17" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Stundenlohn CHF" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding HourlyRateChf, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="17" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="BVG pro Monat CHF" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding MonthlyBvgDeductionChf, Mode=TwoWay}" />
              </StackPanel>

              <TextBlock Grid.Row="18" Grid.ColumnSpan="2" Classes="section-caption" Margin="0,8,0,0" Text="Zuschlagssaetze" />
              <Border Grid.Row="19" Grid.ColumnSpan="2" Margin="0,10,0,0" Background="#FFF8FAFC" CornerRadius="8" Padding="12">
                <TextBlock Foreground="#FF5F6B7A" Text="Nacht-, Sonntags- und Feiertagszuschlaege werden zentral im Bereich Einstellungen gepflegt und nicht mehr pro Mitarbeitendem." TextWrapping="Wrap" />
              </Border>
            </Grid>
          </ScrollViewer>

          <Border Grid.Row="1" Margin="0,12,0,0" Background="#FFF8FAFC" CornerRadius="8" Padding="16" IsVisible="{Binding ShowSettingsWorkspace}">
            <StackPanel Spacing="12">
              <TextBlock FontWeight="SemiBold" Text="Arbeitszeitzuschlaege" />
              <TextBlock Foreground="#FF5F6B7A" Text="Prozentsaetze als Dezimalwerte pflegen, zum Beispiel `0.25` fuer 25 Prozent." TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                  <TextBlock Classes="section-caption" Text="Nachtzuschlag" />
                  <TextBox Text="{Binding SettingsNightSupplementRate, Mode=TwoWay}" Watermark="z. B. 0.25" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                  <TextBlock Classes="section-caption" Text="Sonntagszuschlag" />
                  <TextBox Text="{Binding SettingsSundaySupplementRate, Mode=TwoWay}" Watermark="z. B. 0.50" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="4" Margin="0,10,0,0">
                  <TextBlock Classes="section-caption" Text="Feiertagszuschlag" />
                  <TextBox Text="{Binding SettingsHolidaySupplementRate, Mode=TwoWay}" Watermark="z. B. 1.00" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border
              Grid.Row="2"
              Margin="0,12,0,0"
              Padding="12"
              Background="#FFFFF1E6"
              BorderBrush="#FFF1C18A"
              BorderThickness="1"
              CornerRadius="8"
              IsVisible="{Binding ShowDeleteConfirmation}">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock Foreground="#FF6B4A1F" Text="{Binding DeleteConfirmationText}" TextWrapping="Wrap" />
              <Button Grid.Column="1" Margin="10,0,0,0" Classes="danger-action" Command="{Binding ConfirmDeleteCommand}" Content="Archivieren" />
              <Button Grid.Column="2" Margin="10,0,0,0" Command="{Binding DismissDeleteCommand}" Content="Zurueck" />
            </Grid>
          </Border>

          <Border Grid.Row="3" Background="#FFF8FAFC" CornerRadius="8" Padding="12" Margin="0,12,0,0">
            <TextBlock Foreground="#FF304255" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
          </Border>

          <Grid Grid.Row="4" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="0,12,0,0" IsVisible="{Binding ShowEmployeeWorkspace}">
            <Button Grid.Column="0" Command="{Binding NewEmployeeCommand}" Content="Neu" />
            <Button Grid.Column="1" Margin="10,0,0,0" Command="{Binding EditEmployeeCommand}" Content="Bearbeiten" IsVisible="{Binding ShowViewActions}" />
            <Button Grid.Column="2" Margin="10,0,0,0" Command="{Binding DeleteCommand}" Content="Loeschen" IsVisible="{Binding ShowEditActions}" />
            <Button Grid.Column="4" Margin="10,0,0,0" Command="{Binding CancelCommand}" Content="Abbrechen" IsVisible="{Binding ShowEditActions}" />
            <Button Grid.Column="5" Classes="primary-action" Command="{Binding SaveCommand}" Content="Speichern" IsVisible="{Binding ShowEditActions}" />
          </Grid>

          <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,12,0,0" IsVisible="{Binding ShowSettingsWorkspace}">
            <TextBlock Foreground="#FF5F6B7A" VerticalAlignment="Center" Text="Die Zuschlagssaetze gelten zentral fuer die spaetere Lohnberechnung." TextWrapping="Wrap" />
            <Button Grid.Column="1" Classes="primary-action" Command="{Binding SaveSettingsCommand}" Content="Einstellungen speichern" />
          </Grid>
        </Grid>
      </controls:AppSectionCard>
    </Grid>

    <TextBlock Grid.Row="3" Foreground="#FF5F6B7A" Text="{Binding WorkspaceLabel}" />
  </Grid>
</Window>
