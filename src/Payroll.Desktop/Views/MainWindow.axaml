<Window
    x:Class="Payroll.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Payroll.Desktop.Controls"
    xmlns:styles="clr-namespace:Payroll.Desktop.Styles"
    Title="{Binding Title}"
    Width="1460"
    Height="920"
    MinWidth="1200"
    MinHeight="760"
    Background="{DynamicResource Theme.Color.AppBackground}">
  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="{DynamicResource Theme.Layout.PagePadding}" PointerPressed="OnRootPointerPressed">
    <Border
        Grid.Row="0"
        Classes="surface-panel"
        Padding="{DynamicResource Theme.Layout.PanelPadding}"
        Background="{DynamicResource Theme.Color.Brand}"
        CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}"
        Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
      <Grid ColumnDefinitions="Auto,*">
        <Border Width="48" Height="48" Background="#33FFFFFF" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,12,0">
          <Grid>
            <Image Source="{Binding AppLogoImage}" Stretch="Uniform" IsVisible="{Binding HasAppLogoImage}" />
            <Viewbox Stretch="Uniform" IsVisible="{Binding ShowAppLogoText}">
              <TextBlock Classes="app-title" Text="{Binding AppLogoText}" />
            </Viewbox>
          </Grid>
        </Border>
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock Classes="app-title" Text="{x:Static styles:ThemeTokens.BrandAppName}" />
          <TextBlock Classes="app-subtitle" Text="{x:Static styles:ThemeTokens.BrandAppSubtitle}" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="surface-panel" Padding="{DynamicResource Theme.Layout.PanelPadding}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
      <Grid ColumnDefinitions="Auto,*">
        <ListBox Grid.Column="0"
                 Classes="main-navigation-list"
                 BorderThickness="0"
                 Background="Transparent"
                 ItemsSource="{Binding MainNavigationItems}"
                 SelectedItem="{Binding SelectedMainNavigationItem, Mode=TwoWay}">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="{DynamicResource Theme.Layout.SectionSpacing}" />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Button Content="{Binding Label}"
                      Command="{Binding ActivateCommand}"
                      IsEnabled="{Binding IsEnabled}"
                      Classes.nav-active="{Binding IsSelected}"
                      Classes.nav-placeholder="{Binding IsNotSelected}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <Grid Grid.Column="1" ColumnDefinitions="210,92,34,34" HorizontalAlignment="Right" Margin="8,0,0,0" IsVisible="{Binding ShowEmployeeSelectionArea}">
          <TextBox
              IsEnabled="{Binding CanSearchEmployees}"
              Watermark="Suche Mitarbeitende"
              Text="{Binding SearchText, Mode=TwoWay}" />
          <ComboBox
              Grid.Column="1"
              Margin="4,0,0,0"
              IsEnabled="{Binding CanSearchEmployees}"
              ItemsSource="{Binding ActivityFilters}"
              SelectedItem="{Binding SelectedActivityFilter, Mode=TwoWay}" />
          <Button
              Grid.Column="2"
              Width="34"
              MinWidth="34"
              Height="34"
              Margin="4,0,0,0"
              Command="{Binding SearchCommand}"
              ToolTip.Tip="Suchen">
            <PathIcon Width="16" Height="16" Data="M9.5,3A6.5,6.5 0,0 0 9.5,16A6.47,6.47 0,0 0 13.62,14.59L18.71,19.71L20.12,18.3L15.03,13.21A6.47,6.47 0,0 0 16,9.5A6.5,6.5 0,0 0 9.5,3M9.5,5A4.5,4.5 0,0 1 14,9.5A4.5,4.5 0,0 1 9.5,14A4.5,4.5 0,0 1 5,9.5A4.5,4.5 0,0 1 9.5,5Z" />
          </Button>
          <Button
              Grid.Column="3"
              Width="34"
              MinWidth="34"
              Height="34"
              Margin="4,0,0,0"
              Command="{Binding RefreshCommand}"
              ToolTip.Tip="Aktualisieren">
            <PathIcon Width="16" Height="16" Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0,0 0 4,12A8,8 0,0 0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.82,16.33 14.61,18 12,18A6,6 0,0 1 6,12A6,6 0,0 1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" />
          </Button>
        </Grid>
      </Grid>
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="360,*" MinHeight="0">
      <controls:AppSectionCard Grid.Column="0" Header="Mitarbeitende" Margin="0,0,8,0" IsVisible="{Binding ShowEmployeeSelectionArea}">
        <Grid RowDefinitions="Auto,*" MinHeight="0">
          <TextBlock Grid.Row="0" Foreground="#FF5F6B7A" Text="{Binding EmployeeCountSummary}" />

          <ListBox
              Classes="employee-selection-list"
              Grid.Row="1"
              MinHeight="0"
              Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}"
              BorderThickness="0"
              Background="Transparent"
              IsEnabled="{Binding CanSelectEmployees}"
              ItemsSource="{Binding Employees}"
              SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8" Margin="0,0,0,6" Background="#FFF8FAFC" CornerRadius="6">
                  <StackPanel Spacing="2">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Spacing="1">
                        <TextBlock FontWeight="SemiBold" Text="{Binding FullName}" />
                        <TextBlock Classes="section-caption" Text="{Binding PersonnelNumber}" />
                      </StackPanel>
                      <Border Grid.Column="1" Margin="6,0,0,0" Background="#FFE6EEF5" CornerRadius="999" Padding="6,1">
                        <TextBlock Classes="section-caption" Text="{Binding StatusSummary}" />
                      </Border>
                    </Grid>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </controls:AppSectionCard>

      <controls:AppSectionCard Grid.Column="0" Grid.ColumnSpan="2" Header="Einstellungen" Margin="8,0,0,0" IsVisible="{Binding ShowSettingsWorkspace}">
        <Grid RowDefinitions="Auto,*" MinHeight="0">
          <Border Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
              <StackPanel Spacing="2">
                <TextBlock FontWeight="SemiBold" Text="Berechnungs- und Systemeinstellungen" />
                <TextBlock Foreground="#FF5F6B7A"
                           Text="Die Bereiche werden links ueber eine feste Liste geoeffnet. Rechts bleibt der bestehende Inhalt des gewaehlten Bereichs sichtbar."
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1" Classes="primary-action" Command="{Binding SaveSettingsCommand}" Content="Einstellungen speichern" />
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1" MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Border Background="{DynamicResource Theme.Color.Surface}" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
              <Grid ColumnDefinitions="220,*" MinHeight="0">
                <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}" VerticalAlignment="Top">
                  <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                    <TextBlock FontWeight="SemiBold" Text="Bereiche" />
                    <ListBox BorderThickness="0"
                             Background="Transparent"
                             ItemsSource="{Binding SettingsNavigationItems}"
                             SelectedItem="{Binding SelectedSettingsNavigationItem, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="0">
              <Border IsVisible="{Binding ShowSettingsSystemDbSection}">
                <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                  <TextBlock FontWeight="SemiBold" Text="Aktive Datenbank" />
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,6">
                      <TextBlock Classes="section-caption" Text="Environment" />
                      <TextBox Text="{Binding EnvironmentNameDisplay}" IsReadOnly="True" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="8,0,0,6">
                      <TextBlock Classes="section-caption" Text="Aktiver DB-Pfad" />
                      <TextBox Text="{Binding DatabasePathDisplay}" IsReadOnly="True" />
                    </StackPanel>
                  </Grid>

                  <TextBlock FontWeight="SemiBold" Text="Startparameter" />
                  <TextBlock Foreground="#FF5F6B7A" Text="Der DB-Pfad wird beim Start geladen. Ueberschreibungen erfolgen nicht in den Fach-Settings, sondern ueber appsettings, ENV oder Startparameter." TextWrapping="Wrap" />
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-caption" Text="Moegliche Startparameter" />
                    <TextBox Text="{Binding StartupArgumentsHelp}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Courier New, DejaVu Sans Mono, Consolas" />
                  </StackPanel>
                  <TextBlock Foreground="#FF5F6B7A" Text="ENV-Override: `PAYROLLAPP_DATABASE_PATH=/voller/pfad/zur/datei.db`" TextWrapping="Wrap" />
                  <TextBlock Foreground="#FF5F6B7A" Text="Appsettings: `src/Payroll.Desktop/appsettings.json` und `appsettings.Development.json`." TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border IsVisible="{Binding ShowSettingsLayoutSection}">
                <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                  <TextBlock FontWeight="SemiBold" Text="App allgemein" />
                  <TextBlock Foreground="#FF5F6B7A" Text="Zentrale Screen-Werte fuer Schrift, Farben, Logo und grundlegende Layout-Abstaende. Diese Werte steuern das laufende Programm." TextWrapping="Wrap" />
                  <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                      <TextBlock FontWeight="SemiBold" Text="Layout-Abstaende" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Aeusserer Seitenabstand: Standard 20, gueltig 4 bis 24. Panel-Innenabstand: Standard 12, gueltig 4 bis 16. Section-Abstand: Standard 12, gueltig 2 bis 20. Panel-Abrundung: Standard 8, gueltig 0 bis 16. Tabellen-Zellabstand vertikal: Standard 6, gueltig 2 bis 12." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Aeusserer Seitenabstand" />
                          <TextBox Text="{Binding SettingsAppPagePadding, Mode=TwoWay}" Watermark="20" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
                          <TextBlock Classes="section-caption" Text="Panel-Innenabstand" />
                          <TextBox Text="{Binding SettingsAppPanelPadding, Mode=TwoWay}" Watermark="12" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,8,8,0">
                          <TextBlock Classes="section-caption" Text="Section-Abstand" />
                          <TextBox Text="{Binding SettingsAppSectionSpacing, Mode=TwoWay}" Watermark="12" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="8,8,0,0">
                          <TextBlock Classes="section-caption" Text="Panel-Abrundung" />
                          <TextBox Text="{Binding SettingsAppPanelCornerRadius, Mode=TwoWay}" Watermark="8" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4" Margin="0,8,8,0">
                          <TextBlock Classes="section-caption" Text="Tabellen-Zellabstand vertikal" />
                          <TextBox Text="{Binding SettingsAppTableCellVerticalPadding, Mode=TwoWay}" Watermark="6" />
                        </StackPanel>
                      </Grid>
                    </StackPanel>
                  </Border>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,6">
                  <TextBlock Classes="section-caption" Text="Schriftart" />
                  <TextBox Text="{Binding SettingsAppFontFamily, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="8,0,0,6">
                  <TextBlock Classes="section-caption" Text="Schriftgroesse" />
                  <TextBox Text="{Binding SettingsAppFontSize, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,6,8,0">
                  <TextBlock Classes="section-caption" Text="Schriftfarbe" />
                  <TextBox Text="{Binding SettingsAppTextColorHex, Mode=TwoWay}" Watermark="#FF1A2530" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="8,6,0,0">
                  <TextBlock Classes="section-caption" Text="Hinweisfarbe" />
                  <TextBox Text="{Binding SettingsAppMutedTextColorHex, Mode=TwoWay}" Watermark="#FF5F6B7A" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4" Margin="0,6,8,0">
                  <TextBlock Classes="section-caption" Text="Hintergrundfarbe" />
                  <TextBox Text="{Binding SettingsAppBackgroundColorHex, Mode=TwoWay}" Watermark="#FFF5F7FA" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4" Margin="8,6,0,0">
                  <TextBlock Classes="section-caption" Text="Akzentfarbe" />
                  <TextBox Text="{Binding SettingsAppAccentColorHex, Mode=TwoWay}" Watermark="#FF14324A" />
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4" Margin="0,6,8,0">
                  <TextBlock Classes="section-caption" Text="Logo-Text" />
                  <TextBox Text="{Binding SettingsAppLogoText, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4" Margin="8,6,0,0">
                  <TextBlock Classes="section-caption" Text="Logo-Pfad" />
                  <TextBox Text="{Binding SettingsAppLogoPath, Mode=TwoWay}" />
                </StackPanel>
                  </Grid>

                  <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                    <StackPanel DataContext="{Binding LayoutParameterFiles}" Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                      <TextBlock FontWeight="SemiBold" Text="Layout-Parameterdateien" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Registrierte Layout-Dateien werden direkt als Rohtext geladen. Speichern und Restore arbeiten mit maximal zwei Backups pro Datei." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="260,*" RowDefinitions="Auto,*,Auto" MinHeight="420">
                        <StackPanel Grid.RowSpan="3" Grid.Column="0" Spacing="4" Margin="0,0,12,0">
                          <TextBlock Classes="section-caption" Text="Dateien" />
                          <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile, Mode=TwoWay}" MinHeight="360">
                            <ListBox.ItemTemplate>
                              <DataTemplate>
                                <StackPanel Spacing="2">
                                  <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                  <TextBlock Foreground="#FF5F6B7A" FontSize="12" Text="{Binding RelativePath}" TextWrapping="Wrap" />
                                </StackPanel>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                          <TextBlock Classes="section-caption" Text="Dateipfad" />
                          <TextBox Text="{Binding SelectedFilePath}" IsReadOnly="True" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="0,8,0,0">
                          <TextBlock Classes="section-caption" Text="Inhalt" />
                          <TextBox Text="{Binding EditorText, Mode=TwoWay}" AcceptsReturn="True" MinHeight="320" TextWrapping="NoWrap" FontFamily="Courier New, DejaVu Sans Mono, Consolas" />
                        </StackPanel>

                        <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                          <StackPanel Spacing="4">
                            <TextBlock Classes="section-caption" Text="Backups" />
                            <ComboBox ItemsSource="{Binding Backups}" SelectedItem="{Binding SelectedBackup, Mode=TwoWay}">
                              <ComboBox.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                              </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Foreground="#FF5F6B7A" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                          </StackPanel>
                          <Button Grid.Column="1" Margin="12,22,8,0" Command="{Binding RestoreCommand}" Content="Version wiederherstellen" />
                          <Button Grid.Column="2" Margin="0,22,0,0" Classes="primary-action" Command="{Binding SaveCommand}" Content="Datei speichern" />
                        </Grid>
                      </Grid>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <Border IsVisible="{Binding ShowSettingsListsSection}">
                <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                  <TextBlock FontWeight="SemiBold" Text="Mitarbeitenden-Listen" />
                  <TextBlock Foreground="#FF5F6B7A" Text="Abteilungen, Anstellungskategorien und Anstellungsorte werden zentral gepflegt und im Mitarbeitendenformular als Auswahl verwendet." TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto">
                    <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,8,0">
                      <TextBlock Classes="section-caption" Text="Abteilungen" />
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding NewDepartmentName, Mode=TwoWay}" Watermark="Neue Abteilung" />
                        <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding AddDepartmentOptionCommand}" Content="Hinzufuegen" />
                      </Grid>
                      <ListBox ItemsSource="{Binding DepartmentOptions}" SelectedItem="{Binding SelectedSettingsDepartment, Mode=TwoWay}" MinHeight="120">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto">
                              <TextBox Text="{Binding Name, Mode=TwoWay}" />
                              <CheckBox Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" IsChecked="{Binding IsGavMandatory, Mode=TwoWay}" Content="GAV" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                      <Button Command="{Binding RemoveDepartmentOptionCommand}" Content="Ausgewaehlte Abteilung entfernen" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8" Margin="0,0,8,0">
                      <TextBlock Classes="section-caption" Text="Anstellungskategorien" />
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding NewEmploymentCategoryName, Mode=TwoWay}" Watermark="Neue Kategorie" />
                        <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding AddEmploymentCategoryOptionCommand}" Content="Hinzufuegen" />
                      </Grid>
                      <ListBox ItemsSource="{Binding EmploymentCategoryOptions}" SelectedItem="{Binding SelectedSettingsEmploymentCategory, Mode=TwoWay}" MinHeight="120">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <TextBox Text="{Binding Name, Mode=TwoWay}" />
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                      <Button Command="{Binding RemoveEmploymentCategoryOptionCommand}" Content="Ausgewaehlte Kategorie entfernen" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="8">
                      <TextBlock Classes="section-caption" Text="Anstellungsorte" />
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding NewEmploymentLocationName, Mode=TwoWay}" Watermark="Neuer Ort" />
                        <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding AddEmploymentLocationOptionCommand}" Content="Hinzufuegen" />
                      </Grid>
                      <ListBox ItemsSource="{Binding EmploymentLocationOptions}" SelectedItem="{Binding SelectedSettingsEmploymentLocation, Mode=TwoWay}" MinHeight="120">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <TextBox Text="{Binding Name, Mode=TwoWay}" />
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                      <Button Command="{Binding RemoveEmploymentLocationOptionCommand}" Content="Ausgewaehlten Ort entfernen" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <Border IsVisible="{Binding ShowSettingsCalculationSection}">
                <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                  <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                      <TextBlock FontSize="18" FontWeight="SemiBold" Text="Allgemein" />
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                      <Grid ColumnDefinitions="150,150,Auto,Auto,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Gueltig ab" />
                          <controls:AppDatePicker SelectedDate="{Binding SettingsGeneralValidFrom, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Gueltig bis" />
                          <controls:AppDatePicker SelectedDate="{Binding SettingsGeneralValidTo, Mode=TwoWay}" />
                        </StackPanel>
                        <Button Grid.Column="2" Margin="0,24,8,0" Command="{Binding OpenGeneralSettingsVersionDialogCommand}" Content="Historie anzeigen" />
                        <Button Grid.Column="3" Margin="0,24,0,0" Command="{Binding OpenNewGeneralSettingsVersionDialogCommand}" Content="Neuer Satzstand ab Monat" />
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Zahlenformat" />
                      <Grid ColumnDefinitions="220,220,220">
                        <StackPanel Spacing="4">
                          <TextBlock Classes="section-caption" Text="Dezimaltrennzeichen" />
                          <ComboBox ItemsSource="{Binding DecimalSeparatorOptions}"
                                    SelectedItem="{Binding SettingsDecimalSeparator, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                          <TextBlock Classes="section-caption" Text="Tausendertrennzeichen" />
                          <ComboBox ItemsSource="{Binding ThousandsSeparatorOptions}"
                                    SelectedItem="{Binding SettingsThousandsSeparator, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4" Margin="12,0,0,0">
                          <TextBlock Classes="section-caption" Text="Waehrung" />
                          <TextBox Text="{Binding SettingsCurrencyCode, Mode=TwoWay}" Watermark="CHF" />
                        </StackPanel>
                      </Grid>
                      <TextBlock Foreground="#FF5F6B7A"
                                 Text="Intern wird kulturunabhaengig mit Dezimalwerten gerechnet. Die UI zeigt Zahlen mit dem hier gewaehlten Trennzeichen."
                                 TextWrapping="Wrap" />

                      <TextBlock FontWeight="SemiBold" Text="Lohnausweis" />
                      <TextBlock Foreground="#FF5F6B7A"
                                 Text="Pfad zur PDF-Vorlage fuer den Lohnausweis. Standard ist die Projektvorlage und kann spaeter pro Jahr oder Formularstand ueberschrieben werden."
                                 TextWrapping="Wrap" />
                      <StackPanel Spacing="4">
                        <TextBlock Classes="section-caption" Text="Lohnausweis PDF-Vorlage" />
                        <TextBox Text="{Binding SettingsSalaryCertificatePdfTemplatePath, Mode=TwoWay}" Watermark="resources/forms/dbst-form-11lohna-rechts-dfi-de.pdf" />
                      </StackPanel>

                      <TextBlock FontWeight="SemiBold" Text="Globale Abzuege" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Die Prozentwerte werden als echte Prozentangaben erfasst und intern fuer die Berechnung automatisch in Dezimalwerte umgerechnet." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,6">
                          <TextBlock Classes="section-caption" Text="AHV/IV/EO" />
                          <Grid>
                            <TextBox Padding="8,6,28,6" Text="{Binding SettingsAhvIvEoRate, Mode=TwoWay}" Watermark="5.3" />
                            <TextBlock Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" Text="%" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="8,0,0,6">
                          <TextBlock Classes="section-caption" Text="ALV" />
                          <Grid>
                            <TextBox Padding="8,6,28,6" Text="{Binding SettingsAlvRate, Mode=TwoWay}" Watermark="1.1" />
                            <TextBlock Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" Text="%" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,6,8,0">
                          <TextBlock Classes="section-caption" Text="Krankentaggeld/UVG" />
                          <Grid>
                            <TextBox Padding="8,6,28,6" Text="{Binding SettingsSicknessAccidentInsuranceRate, Mode=TwoWay}" Watermark="0.821" />
                            <TextBlock Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" Text="%" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="8,6,0,0">
                          <TextBlock Classes="section-caption" Text="Aus- und Weiterbildung inkl. Ferien" />
                          <Grid>
                            <TextBox Padding="8,6,28,6" Text="{Binding SettingsTrainingAndHolidayRate, Mode=TwoWay}" Watermark="0.015" />
                            <TextBlock Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" Text="%" />
                          </Grid>
                        </StackPanel>
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Hilfetexte im Lohnlauf" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Nur die wichtigsten Hilfetexte sind hier konfigurierbar. Checkbox steuert die Anzeige, das Textfeld ueberschreibt optional den bestehenden Text in Lohnlauf und PDF." TextWrapping="Wrap" />
                      <ItemsControl ItemsSource="{Binding PayrollPreviewHelpOptions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="260,*" RowDefinitions="Auto" Margin="0,2,0,6">
                              <CheckBox Margin="0,2,12,0" Content="{Binding Label}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                              <TextBox Grid.Column="1" Text="{Binding HelpText, Mode=TwoWay}" AcceptsReturn="False" TextWrapping="NoWrap" Watermark="Leer lassen = bestehenden Text verwenden" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                      <TextBlock FontSize="18" FontWeight="SemiBold" Text="Stundenlohn" />
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                      <Grid ColumnDefinitions="150,150,Auto,Auto,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Gueltig ab" />
                          <controls:AppDatePicker SelectedDate="{Binding SettingsHourlyValidFrom, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Gueltig bis" />
                          <controls:AppDatePicker SelectedDate="{Binding SettingsHourlyValidTo, Mode=TwoWay}" />
                        </StackPanel>
                        <Button Grid.Column="2" Margin="0,24,8,0" Command="{Binding OpenHourlySettingsVersionDialogCommand}" Content="Historie anzeigen" />
                        <Button Grid.Column="3" Margin="0,24,0,0" Command="{Binding OpenNewHourlySettingsVersionDialogCommand}" Content="Neuer Satzstand ab Monat" />
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Arbeitszeitzuschlaege" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Prozentsaetze als echte Prozentwerte pflegen, zum Beispiel `25` oder `25,5` fuer 25 bzw. 25,5 Prozent." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Nachtzuschlag" />
                          <Grid>
                            <TextBox Padding="8,6,28,6" Text="{Binding SettingsNightSupplementRate, Mode=TwoWay}" Watermark="z. B. 25" />
                            <TextBlock Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" Text="%" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Sonntagszuschlag" />
                          <Grid>
                            <TextBox Padding="8,6,28,6" Text="{Binding SettingsSundaySupplementRate, Mode=TwoWay}" Watermark="z. B. 50" />
                            <TextBlock Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" Text="%" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                          <TextBlock Classes="section-caption" Text="Feiertagszuschlag" />
                          <Grid>
                            <TextBox Padding="8,6,28,6" Text="{Binding SettingsHolidaySupplementRate, Mode=TwoWay}" Watermark="z. B. 100" />
                            <TextBlock Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" Text="%" />
                          </Grid>
                        </StackPanel>
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Stundenlohn-spezifische Ansaetze" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Diese Parameter werden weiterhin fuer die bestehende Stundenlohn-Berechnung verwendet." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,6">
                          <TextBlock Classes="section-caption" Text="Ferienentschaedigung" />
                          <Grid>
                            <TextBox Padding="8,6,28,6" Text="{Binding SettingsVacationCompensationRate, Mode=TwoWay}" Watermark="10.64" />
                            <TextBlock Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" Text="%" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="8,0,0,6">
                          <TextBlock Classes="section-caption" Text="Ferienentschaedigung ab 50 Jahren" />
                          <Grid>
                            <TextBox Padding="8,6,28,6" Text="{Binding SettingsVacationCompensationRateAge50Plus, Mode=TwoWay}" Watermark="10.64" />
                            <TextBlock Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False" Text="%" />
                          </Grid>
                        </StackPanel>
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Fahrzeugansaetze" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Die Waehrungswerte werden mit den in der Monatserfassung erfassten Mengen multipliziert." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Pauschalzone 1" />
                          <Grid>
                            <TextBox Padding="54,6,8,6" Text="{Binding SettingsVehiclePauschalzone1RateChf, Mode=TwoWay}" />
                            <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" Text="{Binding CurrencyPrefix}" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Pauschalzone 2" />
                          <Grid>
                            <TextBox Padding="54,6,8,6" Text="{Binding SettingsVehiclePauschalzone2RateChf, Mode=TwoWay}" />
                            <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" Text="{Binding CurrencyPrefix}" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                          <TextBlock Classes="section-caption" Text="Regiezone 1" />
                          <Grid>
                            <TextBox Padding="54,6,8,6" Text="{Binding SettingsVehicleRegiezone1RateChf, Mode=TwoWay}" />
                            <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" Text="{Binding CurrencyPrefix}" />
                          </Grid>
                        </StackPanel>
                      </Grid>
                    </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                      <TextBlock FontSize="18" FontWeight="SemiBold" Text="Monatslohn" />
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                      <Grid ColumnDefinitions="150,150,Auto,Auto,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Gueltig ab" />
                          <controls:AppDatePicker SelectedDate="{Binding SettingsMonthlySalaryValidFrom, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Gueltig bis" />
                          <controls:AppDatePicker SelectedDate="{Binding SettingsMonthlySalaryValidTo, Mode=TwoWay}" />
                        </StackPanel>
                        <Button Grid.Column="2" Margin="0,24,8,0" Command="{Binding OpenMonthlySalarySettingsVersionDialogCommand}" Content="Historie anzeigen" />
                        <Button Grid.Column="3" Margin="0,24,0,0" Command="{Binding OpenNewMonthlySalarySettingsVersionDialogCommand}" Content="Neuer Satzstand ab Monat" />
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Vorbereitung Monatslohn" />
                      <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                        <TextBlock Foreground="#FF5F6B7A"
                                   Text="Dieser Bereich ist als Grundlage fuer spaetere Monatslohn-Parameter vorbereitet. Die aktuelle Payroll-Logik bleibt bewusst auf Stundenlohn fokussiert."
                                   TextWrapping="Wrap" />
                      </Border>
                    </StackPanel>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <Border IsVisible="{Binding ShowSettingsSqlSection}">
                <StackPanel DataContext="{Binding SqlExplorer}" Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                  <TextBlock FontWeight="SemiBold" Text="SQL-Explorer" />
                  <TextBlock Foreground="#FF5F6B7A"
                             Text="Generischer Read-only-Zugriff auf freigegebene Tabellen. Kritische Tabellen bleiben sichtbar, aber bewusst nur lesend."
                             TextWrapping="Wrap" />

                  <Grid ColumnDefinitions="280,120,Auto" RowDefinitions="Auto">
                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                      <TextBlock Classes="section-caption" Text="Tabelle" />
                      <ComboBox ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,8,0">
                      <TextBlock Classes="section-caption" Text="Limit" />
                      <ComboBox ItemsSource="{Binding LimitOptions}" SelectedItem="{Binding SelectedLimit, Mode=TwoWay}" />
                    </StackPanel>
                    <Button Grid.Column="2" Margin="8,22,0,0" Command="{Binding ReloadCommand}" Content="Neu laden" />
                  </Grid>

                  <Border Background="#FFF8FAFC" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="section-caption" Text="Policy" />
                      <TextBlock FontWeight="SemiBold" Text="{Binding SelectedTable.PolicyDisplay}" />
                      <TextBlock Foreground="#FF5F6B7A" Text="{Binding SelectedTablePolicyHint}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>

                  <Border Background="#FFFFF4E5" BorderBrush="#FFF1C18A" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}" IsVisible="{Binding ShowCriticalPolicyWarning}">
                    <TextBlock Foreground="#FF6B4A1F"
                               Text="Diese Tabelle ist kritisch. Historisierung, Snapshots oder Berechnungsbezuege koennen durch direkte Mutation ungueltig werden."
                               TextWrapping="Wrap" />
                  </Border>

                  <TextBlock Foreground="#FF5F6B7A" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                  <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" ClipToBounds="True">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                      <StackPanel Spacing="0">
                        <ItemsControl ItemsSource="{Binding Columns}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Width="{Binding Width}" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Background="#FFF8FAFC" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                                <StackPanel Spacing="2">
                                  <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                  <TextBlock Classes="section-caption" Text="{Binding ColumnHint}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Columns}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Width="{Binding Width}" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Background="#FFFFFFFF" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                                <TextBox Text="{Binding FilterValue, Mode=TwoWay}" Watermark="{Binding FilterWatermark}" />
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ListBox Classes="table-list" ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow, Mode=TwoWay}" MinHeight="220">
                          <ListBox.ItemTemplate>
                            <DataTemplate>
                              <ItemsControl ItemsSource="{Binding Cells}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Border Width="{Binding Width}" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                                      <TextBlock Text="{Binding Value}" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </StackPanel>
                    </ScrollViewer>
                  </Border>

                  <Border Background="#FFF8FAFC" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                      <TextBlock FontWeight="SemiBold" Text="Detailansicht" />
                      <TextBlock Foreground="#FF5F6B7A"
                                 Text="Ausgewaehlte Zeile als Key/Value-Ansicht. Der Explorer bleibt in Schritt 1 strikt read-only."
                                 TextWrapping="Wrap" />
                      <ItemsControl ItemsSource="{Binding SelectedRowDetails}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="260,*" Margin="0,0,0,6">
                              <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                              <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <Border IsVisible="{Binding ShowSettingsPrintSection}">
                <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                  <TextBlock FontWeight="SemiBold" Text="Druck / Print" />
                  <TextBlock Foreground="#FF5F6B7A" Text="Getrennte Werte fuer Ausdrucke und den PDF-Export. Das Druck-Template kann hier direkt angepasst werden." TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,6">
                  <TextBlock Classes="section-caption" Text="Print-Schriftart" />
                  <TextBox Text="{Binding SettingsPrintFontFamily, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="8,0,0,6">
                  <TextBlock Classes="section-caption" Text="Print-Schriftgroesse" />
                  <TextBox Text="{Binding SettingsPrintFontSize, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,6,8,0">
                  <TextBlock Classes="section-caption" Text="Print-Schriftfarbe" />
                  <TextBox Text="{Binding SettingsPrintTextColorHex, Mode=TwoWay}" Watermark="#FF000000" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="8,6,0,0">
                  <TextBlock Classes="section-caption" Text="Print-Hinweisfarbe" />
                  <TextBox Text="{Binding SettingsPrintMutedTextColorHex, Mode=TwoWay}" Watermark="#FF4B5563" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4" Margin="0,6,8,0">
                  <TextBlock Classes="section-caption" Text="Print-Akzentfarbe" />
                  <TextBox Text="{Binding SettingsPrintAccentColorHex, Mode=TwoWay}" Watermark="#FFFFFF00" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4" Margin="8,6,0,0">
                  <TextBlock Classes="section-caption" Text="Print-Logo-Text" />
                  <TextBox Text="{Binding SettingsPrintLogoText, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Spacing="4" Margin="0,6,0,0">
                  <TextBlock Classes="section-caption" Text="Print-Logo-Pfad" />
                  <TextBox Text="{Binding SettingsPrintLogoPath, Mode=TwoWay}" />
                </StackPanel>
                  </Grid>

                  <TextBlock FontWeight="SemiBold" Text="PDF-Kopfbereich" />
                  <TextBlock Foreground="#FF5F6B7A" Text="Die Firmenadresse wird fuer die Lohnabrechnung oben links verwendet und mehrzeilig gepflegt." TextWrapping="Wrap" />
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-caption" Text="Firmenadresse" />
                    <TextBox Text="{Binding SettingsCompanyAddress, Mode=TwoWay}" AcceptsReturn="True" Height="120" TextWrapping="Wrap" Watermark="Firmenname&#x0a;Strasse oder Postfach&#x0a;PLZ Ort&#x0a;Webseite&#x0a;E-Mail" />
                  </StackPanel>

                  <TextBlock FontWeight="SemiBold" Text="Druck-Template" />
                  <TextBlock Foreground="#FF5F6B7A" Text="{}Das Template wird mit Platzhaltern gespeichert und beim PDF-Export mit Lohndaten gefuellt. Beispiel-Platzhalter: {{Firmenadresse}}, {{MitarbeiterName}}, {{Basislohn}}, {{TotalAuszahlung}}." TextWrapping="Wrap" />
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-caption" Text="Template-Inhalt" />
                    <TextBox Text="{Binding SettingsPrintTemplate, Mode=TwoWay}" AcceptsReturn="True" Height="320" TextWrapping="Wrap" FontFamily="Courier New, DejaVu Sans Mono, Consolas" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border IsVisible="{Binding ShowSettingsBackupSection}">
                <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                  <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                    <TextBlock FontWeight="SemiBold" Text="Backup erstellen" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Konfiguration, Nutzdaten oder beides als Sicherungsdatei exportieren. Zielpfad und Dateiname koennen frei angepasst werden." TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                      <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,6">
                        <TextBlock Classes="section-caption" Text="Backup-Typ" />
                        <ComboBox ItemsSource="{Binding BackupContentTypeOptions}" SelectedItem="{Binding SelectedBackupContentType, Mode=TwoWay}" />
                      </StackPanel>
                      <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="8,0,0,6">
                        <TextBlock Classes="section-caption" Text="Dateiname" />
                        <TextBox Text="{Binding BackupFileName, Mode=TwoWay}" Watermark="backup_2026-04-07_14-35" />
                      </StackPanel>
                      <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="4" Margin="0,6,0,0">
                        <TextBlock Classes="section-caption" Text="Zielpfad" />
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBox Text="{Binding BackupDirectoryPath, Mode=TwoWay}" />
                          <Button Grid.Column="1" Margin="8,0,0,0" Content="Ordner waehlen" Click="OnBrowseBackupDirectoryClick" />
                        </Grid>
                      </StackPanel>
                      <Button Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Margin="8,10,0,0" Classes="primary-action" Command="{Binding CreateBackupCommand}" Content="Backup erstellen" />
                    </Grid>
                  </StackPanel>

                  <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                    <TextBlock FontWeight="SemiBold" Text="Restore einspielen" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Eine vorhandene Sicherungsdatei einspielen. Der Restore-Typ muss zur enthaltenen Sicherungsart passen." TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                      <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,6">
                        <TextBlock Classes="section-caption" Text="Restore-Typ" />
                        <ComboBox ItemsSource="{Binding BackupContentTypeOptions}" SelectedItem="{Binding SelectedRestoreContentType, Mode=TwoWay}" />
                      </StackPanel>
                      <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="4" Margin="0,6,0,0">
                        <TextBlock Classes="section-caption" Text="Backup-Datei" />
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBox Text="{Binding RestoreFilePath, Mode=TwoWay}" Watermark="/pfad/zur/backup.payrollbackup.json" />
                          <Button Grid.Column="1" Margin="8,0,0,0" Content="Datei waehlen" Click="OnBrowseRestoreFileClick" />
                        </Grid>
                      </StackPanel>
                      <Button Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Margin="8,10,0,0" Command="{Binding RestoreBackupCommand}" Content="Restore starten" />
                    </Grid>
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border IsVisible="{Binding ShowSettingsImportSection}">
                <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                  <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                      <TextBlock FontSize="18" FontWeight="SemiBold" Text="Personendaten" />
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                      <TextBlock FontWeight="SemiBold" Text="CSV-Datei laden" />
                      <TextBlock Foreground="#FF5F6B7A" Text="CSV-Datei waehlen, Aufbau pruefen und anschliessend die Spalten auf die Felder des Lohnprogramms abbilden." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="4">
                          <TextBlock Classes="section-caption" Text="CSV-Datei" />
                          <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox Text="{Binding PersonImportCsvFilePath, Mode=TwoWay}" Watermark="/pfad/zur/personen.csv" />
                            <Button Grid.Column="1" Margin="8,0,0,0" Content="Datei waehlen" Click="OnBrowsePersonImportCsvClick" />
                            <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding LoadPersonImportCsvCommand}" Content="CSV laden" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,8,8,0">
                          <TextBlock Classes="section-caption" Text="Trenner" />
                          <ComboBox Width="160" ItemsSource="{Binding PersonImportDelimiterOptions}" SelectedItem="{Binding SelectedPersonImportDelimiter, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="8,8,0,0">
                          <TextBlock Classes="section-caption" Text="Textqualifier" />
                          <Grid ColumnDefinitions="Auto,*">
                            <CheckBox Content="Felder ummantelt" IsChecked="{Binding PersonImportFieldsEnclosed, Mode=TwoWay}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" Width="240" Margin="12,0,0,0" ItemsSource="{Binding PersonImportTextQualifierOptions}" SelectedItem="{Binding SelectedPersonImportTextQualifier, Mode=TwoWay}" />
                          </Grid>
                        </StackPanel>
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Mapping speichern / laden" />
                      <Grid ColumnDefinitions="*,Auto,*,Auto" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Konfigurationsname" />
                          <TextBox Text="{Binding PersonImportConfigurationName, Mode=TwoWay}" Watermark="z. B. Personendaten Standard-CSV" />
                        </StackPanel>
                        <Button Grid.Column="1" Margin="8,22,12,0" VerticalAlignment="Top" Command="{Binding SavePersonImportConfigurationCommand}" Content="Mapping speichern" />
                        <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Gespeicherte Mappings" />
                          <ComboBox ItemsSource="{Binding PersonImportConfigurations}" SelectedItem="{Binding SelectedPersonImportConfiguration, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                        </StackPanel>
                        <Button Grid.Column="3" Margin="8,22,0,0" VerticalAlignment="Top" Command="{Binding LoadPersonImportConfigurationCommand}" Content="Mapping laden" />
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Mapping-Tabelle" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Muss-Felder sind mit `*` markiert. Der Import bleibt gesperrt, bis alle Muss-Felder einer vorhandenen CSV-Spalte zugeordnet sind." TextWrapping="Wrap" />
                      <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                        <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                          <Grid ColumnDefinitions="1.1*,1.4*,Auto">
                            <TextBlock FontWeight="SemiBold" Text="Feld des Lohnprogramms" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="CSV-Spalte" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Leer erlaubt" />
                          </Grid>
                          <ItemsControl ItemsSource="{Binding PersonImportFieldMappings}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Grid ColumnDefinitions="1.1*,1.4*,Auto" Margin="0,0,0,6">
                                  <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="*" Foreground="#FFC95F36" Margin="0,0,6,0" IsVisible="{Binding IsRequired}" />
                                    <TextBlock Grid.Column="1" Text="{Binding FieldLabel}" />
                                  </Grid>
                                  <AutoCompleteBox Grid.Column="1"
                                                   ItemsSource="{Binding AvailableCsvColumns}"
                                                   SelectedItem="{Binding SelectedCsvColumn, Mode=TwoWay}"
                                                   Text="{Binding CsvColumnSearchText, Mode=TwoWay}"
                                                   MinimumPrefixLength="0"
                                                   FilterMode="ContainsOrdinal"
                                                   IsTextCompletionEnabled="False" />
                                  <CheckBox Grid.Column="2"
                                            Margin="12,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding AllowEmpty, Mode=TwoWay}" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>

                      <TextBlock Foreground="#FF5F6B7A" Text="{Binding PersonImportStatusMessage}" TextWrapping="Wrap" />
                      <Button HorizontalAlignment="Right" Classes="primary-action" Content="Personendaten importieren" Click="OnOpenPersonImportPreviewClick" />
                    </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                      <TextBlock FontSize="18" FontWeight="SemiBold" Text="Stundendaten" />
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                      <TextBlock FontWeight="SemiBold" Text="CSV-Datei laden" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Datei waehlen, Spalten fuer den Stundenimport zuordnen und den Importmonat explizit festlegen. Trenner und Quotes werden fuer diesen Matrix-Import automatisch erkannt. Das Datum kommt nicht aus der Datei, sondern aus dem Importkontext." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="4">
                          <TextBlock Classes="section-caption" Text="CSV-Datei" />
                          <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox Text="{Binding TimeImportCsvFilePath, Mode=TwoWay}" Watermark="/pfad/zur/stunden.csv" />
                            <Button Grid.Column="1" Margin="8,0,0,0" Content="Datei waehlen" Click="OnBrowseTimeImportCsvClick" />
                            <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding LoadTimeImportCsvCommand}" Content="CSV laden" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="4" Margin="0,8,0,0">
                          <TextBlock Classes="section-caption" Text="Importmonat" />
                          <controls:MonthPicker SelectedDate="{Binding TimeImportMonth, Mode=TwoWay}" Watermark="MM/YYYY" />
                        </StackPanel>
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Mapping speichern / laden" />
                      <Grid ColumnDefinitions="*,Auto,*,Auto" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Konfigurationsname" />
                          <TextBox Text="{Binding TimeImportConfigurationName, Mode=TwoWay}" Watermark="z. B. Stundendaten Standard-CSV" />
                        </StackPanel>
                        <Button Grid.Column="1" Margin="8,22,12,0" VerticalAlignment="Top" Command="{Binding SaveTimeImportConfigurationCommand}" Content="Mapping speichern" />
                        <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,8,0">
                          <TextBlock Classes="section-caption" Text="Gespeicherte Mappings" />
                          <ComboBox ItemsSource="{Binding TimeImportConfigurations}" SelectedItem="{Binding SelectedTimeImportConfiguration, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                        </StackPanel>
                        <Button Grid.Column="3" Margin="8,22,0,0" VerticalAlignment="Top" Command="{Binding LoadTimeImportConfigurationCommand}" Content="Mapping laden" />
                      </Grid>

                      <TextBlock FontWeight="SemiBold" Text="Mapping-Tabelle" />
                      <TextBlock Foreground="#FF5F6B7A" Text="Muss-Felder sind mit `*` markiert. Der Import bleibt gesperrt, bis CSV geladen, Muss-Felder zugeordnet und der Importmonat gesetzt ist." TextWrapping="Wrap" />
                      <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                        <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                          <Grid ColumnDefinitions="1.1*,1.4*,Auto">
                            <TextBlock FontWeight="SemiBold" Text="Feld des Lohnprogramms" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="CSV-Spalte" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Leer erlaubt" />
                          </Grid>
                          <ItemsControl ItemsSource="{Binding TimeImportFieldMappings}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Grid ColumnDefinitions="1.1*,1.4*,Auto" Margin="0,0,0,6">
                                  <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="*" Foreground="#FFC95F36" Margin="0,0,6,0" IsVisible="{Binding IsRequired}" />
                                    <TextBlock Grid.Column="1" Text="{Binding FieldLabel}" />
                                  </Grid>
                                  <AutoCompleteBox Grid.Column="1"
                                                   ItemsSource="{Binding AvailableCsvColumns}"
                                                   SelectedItem="{Binding SelectedCsvColumn, Mode=TwoWay}"
                                                   Text="{Binding CsvColumnSearchText, Mode=TwoWay}"
                                                   MinimumPrefixLength="0"
                                                   FilterMode="ContainsOrdinal"
                                                   IsTextCompletionEnabled="False" />
                                  <CheckBox Grid.Column="2"
                                            Margin="12,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding AllowEmpty, Mode=TwoWay}" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>

                      <TextBlock FontWeight="SemiBold" Text="Importierte Monate" />
                      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                        <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                          <ScrollViewer MaxHeight="180" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding ImportedTimeMonths}" SelectedItem="{Binding SelectedImportedTimeMonth, Mode=TwoWay}" BorderThickness="0" Background="Transparent">
                              <ListBox.ItemTemplate>
                                <DataTemplate>
                                  <Grid ColumnDefinitions="160,*" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding DisplayName}" />
                                    <TextBlock Grid.Column="1" Foreground="#FF5F6B7A" Text="{Binding ImportedAtUtc}" />
                                  </Grid>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                          </ScrollViewer>
                        </Border>
                        <Button Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top" Content="Monat loeschen" Click="OnDeleteImportedTimeMonthClick" IsEnabled="{Binding CanDeleteImportedTimeMonth}" />
                      </Grid>

                      <TextBlock Foreground="#FF5F6B7A" Text="{Binding TimeImportStatusMessage}" TextWrapping="Wrap" />
                      <Border IsVisible="{Binding HasTimeImportWarnings}" Background="#FFF7F8EB" BorderBrush="#FFD6DCA5" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="10,8">
                        <TextBlock Foreground="#FF596116" Text="{Binding TimeImportWarningMessage}" TextWrapping="Wrap" />
                      </Border>
                      <Border IsVisible="{Binding HasTimeImportBlockedReasons}" Background="#FFF8F2E8" BorderBrush="#FFE3C8A5" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="10,8">
                        <TextBlock Foreground="#FF7A4C10" Text="{Binding TimeImportBlockedReason}" TextWrapping="Wrap" />
                      </Border>
                      <Button HorizontalAlignment="Right" Classes="primary-action" Content="Stundendaten importieren" Click="OnImportTimeDataClick" IsEnabled="{Binding CanImportTimeData}" />
                    </StackPanel>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
                </StackPanel>
              </Grid>
            </Border>
          </ScrollViewer>
        </Grid>
      </controls:AppSectionCard>

      <controls:AppSectionCard Grid.Column="0" Grid.ColumnSpan="2" Header="Hilfe" Margin="8,0,0,0" IsVisible="{Binding ShowHelpWorkspace}">
        <Grid ColumnDefinitions="220,*" MinHeight="0" DataContext="{Binding LayoutParameterHelp}">
          <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}" VerticalAlignment="Top">
            <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
              <TextBlock FontWeight="SemiBold" Text="Bereiche" />
              <ListBox BorderThickness="0"
                       Background="Transparent"
                       ItemsSource="{Binding NavigationItems}"
                       SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
          </Border>

          <ScrollViewer Grid.Column="1" Margin="12,0,0,0" MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
              <Border Background="{DynamicResource Theme.Color.Surface}" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                <StackPanel Spacing="4">
                  <TextBlock FontSize="18" FontWeight="SemiBold" Text="Hilfe" />
                  <TextBlock Foreground="#FF5F6B7A" Text="Erklaerungen und visuelle Orientierung fuer zentrale Systemparameter sind bewusst von den Bearbeitungsseiten getrennt." TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" IsVisible="{Binding ShowOverviewSection}">
                <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                  <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                    <TextBlock FontWeight="SemiBold" Text="Einstellungen im Ueberblick" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Die Seite `Einstellungen` dient nur der Konfiguration. Erklaerungen und Dokumentation sind bewusst in `Hilfe` ausgelagert." TextWrapping="Wrap" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Die Bereiche in `Einstellungen` sind: `Layout`, `Listen`, `Berechnung` und `Druck / PDF`." TextWrapping="Wrap" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Alle dort gepflegten Werte gelten zentral fuer das System und nicht nur fuer eine einzelne Person oder einen einzelnen Lohnlauf." TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                  <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                    <TextBlock FontWeight="SemiBold" Text="Wichtige Informationen" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Aenderungen in `Berechnung` wirken sich direkt auf die Lohn-Vorschau und den PDF-Export aus." TextWrapping="Wrap" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Prozent-Parameter werden in `Einstellungen > Berechnung` jetzt als echte Prozentwerte gepflegt, also z. B. `5,3` fuer 5,3 Prozent und nicht mehr `0,053`." TextWrapping="Wrap" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Intern rechnet das System weiterhin mit Dezimalbruchwerten. Die Umrechnung zwischen Anzeige und Berechnung passiert automatisch." TextWrapping="Wrap" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Aenderungen im Bereich `Listen` beeinflussen Auswahlwerte im Mitarbeitendenformular und sollten nur mit fachlich abgestimmten Begriffen gepflegt werden." TextWrapping="Wrap" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Das Druck-Template in `Druck / PDF` ist technisch frei anpassbar. Falsch geschriebene Platzhalter fuehren aber dazu, dass Inhalte im PDF leer bleiben." TextWrapping="Wrap" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Aenderungen an Layout- oder Print-Farben beeinflussen nur die Darstellung, nicht die Berechnungslogik." TextWrapping="Wrap" />
                    <TextBlock Foreground="#FF5F6B7A" Text="Wenn ein Template stark angepasst wird, sollte die PDF-Ausgabe danach immer einmal mit echten Lohndaten kontrolliert werden." TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                  <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                    <TextBlock FontWeight="SemiBold" Text="Wie das Template funktioniert" />
                    <TextBlock Foreground="#FF5F6B7A" Text="{}Das Druck-Template besteht aus Zeilen mit einem Tag am Anfang. Nach dem Tag folgen Parameter, getrennt durch `|`. Platzhalter wie `{{Monat}}` oder `{{Basislohn}}` werden beim PDF-Export automatisch ersetzt." TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                  <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                    <TextBlock FontWeight="SemiBold" Text="Template-Tags" />
                    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                      <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="LOGO" />
                      <TextBlock Grid.Row="0" Grid.Column="1" Foreground="#FF5F6B7A" Text="{}Zeigt das Logo oder den Logo-Text im Kopf links oben. Beispiel: `LOGO|{{Logo}}`." TextWrapping="Wrap" />
                      <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="COMPANY_BLOCK" />
                      <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#FF5F6B7A" Text="{}Mehrzeiliger Firmenblock links oben. Beispiel: `COMPANY_BLOCK|{{Firmenadresse}}`." TextWrapping="Wrap" />
                      <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="EMPLOYEE_BLOCK" />
                      <TextBlock Grid.Row="2" Grid.Column="1" Foreground="#FF5F6B7A" Text="{}Mehrzeiliger Mitarbeiterblock rechts oben. Beispiel: `EMPLOYEE_BLOCK|{{MitarbeiterBlock}}`." TextWrapping="Wrap" />
                      <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="AHV_LINE" />
                      <TextBlock Grid.Row="3" Grid.Column="1" Foreground="#FF5F6B7A" Text="{}Freie Kopfzeile fuer AHV-Nummer oder andere Kennungen. Beispiel: `AHV_LINE|AHV Nr. {{AhvNummer}}`." TextWrapping="Wrap" />
                      <TextBlock Grid.Row="4" Grid.Column="0" FontWeight="SemiBold" Text="BANNER" />
                      <TextBlock Grid.Row="4" Grid.Column="1" Foreground="#FF5F6B7A" Text="Gelber Titelbalken mit Titel und Monat. Parameter: Titel | Monat." TextWrapping="Wrap" />
                      <TextBlock Grid.Row="5" Grid.Column="0" FontWeight="SemiBold" Text="META_ROW" />
                      <TextBlock Grid.Row="5" Grid.Column="1" Foreground="#FF5F6B7A" Text="Metadatenzeile mit linker und rechter Bezeichnung/Wert-Kombination. Parameter: links Label | links Wert | rechts Label | rechts Wert." TextWrapping="Wrap" />
                      <TextBlock Grid.Row="6" Grid.Column="0" FontWeight="SemiBold" Text="TABLE_HEADER" />
                      <TextBlock Grid.Row="6" Grid.Column="1" Foreground="#FF5F6B7A" Text="Tabellenkopf fuer die Payroll-Zeilen. Parameter: Bezeichnung | Einheit | Ansatz | Betrag." TextWrapping="Wrap" />
                      <TextBlock Grid.Row="7" Grid.Column="0" FontWeight="SemiBold" Text="PAYROLL_LINE" />
                      <TextBlock Grid.Row="7" Grid.Column="1" Foreground="#FF5F6B7A" Text="Normale oder hervorgehobene Lohnzeile. Parameter: Stil (`regular` oder `emphasis`) | Label | Menge | Ansatz | Betrag | Detail. Im Feld `Ansatz` koennen je nach Position CHF-Werte oder echte Prozentwerte wie `5,3 %` stehen." TextWrapping="Wrap" />
                      <TextBlock Grid.Row="8" Grid.Column="0" FontWeight="SemiBold" Text="SPACER" />
                      <TextBlock Grid.Row="8" Grid.Column="1" Foreground="#FF5F6B7A" Text="Fuegt vertikalen Abstand ein. Parameter: Hoehe in Punkten. Beispiel: `SPACER|12`." TextWrapping="Wrap" />
                      <TextBlock Grid.Row="9" Grid.Column="0" FontWeight="SemiBold" Text="NOTES_BLOCK / CLOSING" />
                      <TextBlock Grid.Row="9" Grid.Column="1" Foreground="#FF5F6B7A" Text="`NOTES_BLOCK` zeigt Hinweise unterhalb der Tabelle. `CLOSING` erzeugt Schlusszeilen wie Grussformel oder Firmenname." TextWrapping="Wrap" />
                    </Grid>
                  </StackPanel>
                </Border>
              </StackPanel>

              <ItemsControl ItemsSource="{Binding Groups}" IsVisible="{Binding ShowLayoutParametersSection}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}" Margin="0,0,0,12">
                      <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                        <StackPanel Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                          <TextBlock Foreground="#FF5F6B7A" Text="{Binding Summary}" TextWrapping="Wrap" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Parameters}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                                <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                                  <Grid ColumnDefinitions="260,220,*">
                                    <StackPanel Spacing="4" Margin="0,0,8,0">
                                      <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                      <TextBlock Foreground="#FF5F6B7A" Text="{Binding Description}" TextWrapping="Wrap" />
                                      <TextBlock Classes="section-caption" Text="{Binding ParameterTypeLabel}" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" Margin="8,0">
                                      <TextBlock Classes="section-caption" Text="Betroffener UI-Bereich" />
                                      <TextBlock Text="{Binding PreviewTarget}" TextWrapping="Wrap" />
                                      <TextBlock Foreground="#FF5F6B7A" Text="{Binding PreviewExplanation}" TextWrapping="Wrap" />
                                      <TextBlock Classes="section-caption" Text="Quelle" Margin="0,6,0,0" />
                                      <TextBlock Foreground="#FF5F6B7A" Text="{Binding Source}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4" Margin="8,0,0,0">
                                      <TextBlock Classes="section-caption" Text="{Binding ValueInputLabel}" />
                                      <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding IsColorParameter}">
                                        <TextBox Text="{Binding LocalValue, Mode=TwoWay}" Watermark="{Binding ExampleValue}" />
                                        <Border Grid.Column="1" Width="40" Height="32" Margin="8,0,0,0" Background="{Binding ColorSwatchBrush}" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="6" />
                                      </Grid>
                                      <ItemsControl ItemsSource="{Binding ColorPresets}" IsVisible="{Binding IsColorParameter}">
                                        <ItemsControl.ItemsPanel>
                                          <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                          </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate>
                                            <Button Width="24" Height="24" Padding="0" Command="{Binding SelectCommand}" Background="{Binding Brush}" BorderBrush="#FFD7E1EA" BorderThickness="1" ToolTip.Tip="{Binding HexValue}" />
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                      <Grid ColumnDefinitions="Auto,*,Auto" IsVisible="{Binding ShowNumericEditor}">
                                        <Button Content="-" Width="28" Command="{Binding DecreaseNumericValueCommand}" />
                                        <TextBox Grid.Column="1" Margin="8,0" Text="{Binding LocalValue, Mode=TwoWay}" Watermark="{Binding ExampleValue}" HorizontalContentAlignment="Center" />
                                        <Button Grid.Column="2" Content="+" Width="28" Command="{Binding IncreaseNumericValueCommand}" />
                                      </Grid>
                                      <CheckBox Content="Lokal aktiv" IsChecked="{Binding LocalBooleanValue, Mode=TwoWay}" IsVisible="{Binding IsBooleanParameter}" />
                                      <TextBox Text="{Binding LocalValue, Mode=TwoWay}" Watermark="{Binding ExampleValue}" IsVisible="{Binding ShowPlainValueEditor}" />
                                      <TextBlock Foreground="#FF5F6B7A" Text="{}Aktueller lokaler Wert" TextWrapping="Wrap" />
                                      <TextBlock Foreground="#FF5F6B7A" Text="{Binding LocalValue}" TextWrapping="Wrap" />
                                    </StackPanel>
                                  </Grid>

                                  <Border Background="#FFF8FAFC" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                                    <StackPanel Spacing="8">
                                      <TextBlock Classes="section-caption" Text="Lokale Vorschau" />
                                      <TextBlock Foreground="#FF5F6B7A" Text="{Binding PreviewExplanation}" TextWrapping="Wrap" />

                                      <Border IsVisible="{Binding ShowPagePaddingPreview}" Background="#FFE9EEF5" CornerRadius="8" Padding="{Binding PagePaddingPreviewMargin}">
                                        <Border Background="#FFFFFFFF" BorderBrush="#FF9FB6CC" BorderThickness="2" CornerRadius="8" Padding="14">
                                          <TextBlock HorizontalAlignment="Center" Text="Mehr PagePadding = Inhalt weiter vom Rand" />
                                        </Border>
                                      </Border>

                                      <Border IsVisible="{Binding ShowPanelPaddingPreview}" Background="#FFF2F5F9" CornerRadius="8" Padding="12">
                                        <Border Background="#FFFFFFFF" BorderBrush="#FF9FB6CC" BorderThickness="2" CornerRadius="8" Padding="{Binding PanelPaddingPreviewPadding}">
                                          <TextBlock HorizontalAlignment="Center" Text="Mehr PanelPadding = mehr Innenraum" />
                                        </Border>
                                      </Border>

                                      <Border IsVisible="{Binding ShowSectionSpacingPreview}" Background="#FFF2F5F9" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="{Binding SectionSpacingPreviewSpacing}">
                                          <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="8" Padding="12">
                                            <TextBlock Text="Erste Sektion" />
                                          </Border>
                                          <Border Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="8" Padding="12">
                                            <TextBlock Text="Zweite Sektion" />
                                          </Border>
                                        </StackPanel>
                                      </Border>

                                      <Border IsVisible="{Binding ShowTableCellPaddingPreview}" Background="#FFF2F5F9" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="0">
                                          <Grid ColumnDefinitions="140,120" Background="#FFF8FAFC">
                                            <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{Binding TableCellPaddingPreviewPadding}">
                                              <TextBlock FontWeight="SemiBold" Text="Monat" />
                                            </Border>
                                            <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{Binding TableCellPaddingPreviewPadding}">
                                              <TextBlock FontWeight="SemiBold" Text="Stunden" />
                                            </Border>
                                          </Grid>
                                          <Grid ColumnDefinitions="140,120">
                                            <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{Binding TableCellPaddingPreviewPadding}">
                                              <TextBlock Text="04.2026" />
                                            </Border>
                                            <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{Binding TableCellPaddingPreviewPadding}">
                                              <TextBlock Text="168.50" />
                                            </Border>
                                          </Grid>
                                        </StackPanel>
                                      </Border>

                                      <Grid IsVisible="{Binding ShowCornerRadiusPreview}" ColumnDefinitions="*,*" Margin="0,0,0,2">
                                        <Border Background="#FFFFFFFF" BorderBrush="#FF9FB6CC" BorderThickness="2" CornerRadius="{Binding CornerRadiusPreviewValue}" Padding="16" Margin="0,0,6,0">
                                          <TextBlock HorizontalAlignment="Center" Text="Panelform" />
                                        </Border>
                                        <Border Grid.Column="1" Background="#FFF8FAFC" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{Binding CornerRadiusPreviewValue}" Padding="16" Margin="6,0,0,0">
                                          <TextBlock HorizontalAlignment="Center" Text="gleiche Rundung" />
                                        </Border>
                                      </Grid>

                                      <StackPanel IsVisible="{Binding ShowFontFamilyPreview}" Spacing="6">
                                        <TextBlock FontFamily="{Binding FontFamilyPreviewValue}" FontSize="18" Text="Vorschau fuer die Schriftfamilie" />
                                        <TextBlock FontFamily="{Binding FontFamilyPreviewValue}" Foreground="#FF5F6B7A" Text="Der Testwert wirkt nur auf diese Vorschauzeile." />
                                      </StackPanel>

                                      <StackPanel IsVisible="{Binding ShowFontSizePreview}" Spacing="6">
                                        <TextBlock FontSize="{Binding FontSizePreviewValue}" Text="Vorschau fuer die Schriftgroesse" />
                                        <TextBlock FontSize="{Binding FontSizePreviewValue}" Foreground="#FF5F6B7A" Text="Groesserer Wert = mehr Gewicht und Platzbedarf." />
                                      </StackPanel>

                                      <Border IsVisible="{Binding ShowTextColorPreview}" Background="#FFF5F7FA" CornerRadius="8" Padding="12">
                                        <TextBlock Foreground="{Binding TextColorPreviewBrush}" Text="Haupttext in lokaler Vorschaufarbe" />
                                      </Border>

                                      <Border IsVisible="{Binding ShowMutedTextColorPreview}" Background="#FFF5F7FA" CornerRadius="8" Padding="12">
                                        <TextBlock Foreground="{Binding MutedTextColorPreviewBrush}" Text="Hinweistext in lokaler Vorschaufarbe" />
                                      </Border>

                                      <Border IsVisible="{Binding ShowBackgroundColorPreview}" Background="{Binding BackgroundColorPreviewBrush}" CornerRadius="8" Padding="12" BorderBrush="#FFD7E1EA" BorderThickness="1">
                                        <TextBlock Foreground="#FF1A2530" Text="Fenster- oder Flaechenhintergrund in lokaler Vorschaufarbe" TextWrapping="Wrap" />
                                      </Border>

                                      <Border IsVisible="{Binding ShowAccentColorPreview}" Background="#FFF5F7FA" CornerRadius="8" Padding="12">
                                        <Border Background="{Binding AccentColorPreviewBrush}" CornerRadius="8" Padding="10">
                                          <TextBlock Foreground="White" Text="Akzentbereich" />
                                        </Border>
                                      </Border>

                                      <Border IsVisible="{Binding ShowLogoTextPreview}" Background="{Binding AccentColorPreviewBrush}" CornerRadius="8" Padding="12">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                                          <Border Width="52" Height="52" Background="#33FFFFFF" CornerRadius="10">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold" Text="{Binding LogoTextPreviewValue}" />
                                          </Border>
                                          <TextBlock HorizontalAlignment="Center" Foreground="White" Text="Textlogo nur fuer diese Zeile" />
                                        </StackPanel>
                                      </Border>

                                      <Border IsVisible="{Binding ShowLogoPathPreview}" Background="#FFF5F7FA" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="8">
                                          <Border Width="90" Height="56" Background="#FFE2E8F0" CornerRadius="8">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF5F6B7A" Text="Bildlogo" />
                                          </Border>
                                          <TextBlock Foreground="#FF5F6B7A" Text="{Binding LogoPathPreviewValue}" TextWrapping="Wrap" />
                                        </StackPanel>
                                      </Border>
                                    </StackPanel>
                                  </Border>
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </controls:AppSectionCard>

      <Border
          Grid.Column="1"
          Margin="8,0,0,0"
          Background="{DynamicResource Theme.Color.Surface}"
          BorderBrush="{DynamicResource Theme.Color.Border}"
          BorderThickness="1"
          CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}"
          Padding="{DynamicResource Theme.Layout.PanelPadding}"
          IsVisible="{Binding ShowPrimaryWorkspaceArea}">
        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto" MinHeight="0">
          <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}" IsVisible="{Binding ShowPrimaryWorkspaceHeader}">
            <Grid>
              <Grid IsVisible="{Binding ShowPayrollRunsWorkspace}" ColumnDefinitions="220,220,*,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-caption" Text="Abrechnungsmonat" />
                  <controls:MonthPicker SelectedDate="{Binding MonthlyRecord.SelectedMonthPickerDate, Mode=TwoWay}" Watermark="MM/YYYY" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="4">
                  <TextBlock Classes="section-caption" Text="Auszahlungsdatum" />
                  <controls:AppDatePicker SelectedDate="{Binding PayrollPaymentDate, Mode=TwoWay}" Watermark="TT.MM.JJJJ" />
                </StackPanel>
                <StackPanel Grid.Column="3"
                            MinWidth="120"
                            Margin="0,0,8,0"
                            VerticalAlignment="Bottom"
                            Spacing="2">
                  <TextBlock Classes="section-caption" Text="Status" />
                  <TextBlock Classes="payroll-status"
                             Classes.payroll-status-finalized="{Binding PayrollRunIsFinalized}"
                             Classes.payroll-status-open="{Binding PayrollRunIsOpen}"
                             Classes.payroll-status-cancelled="{Binding PayrollRunIsCancelled}"
                             Text="{Binding PayrollRunStatusDisplay}" />
                </StackPanel>
                <ToggleButton Grid.Column="4"
                              MinWidth="132"
                              Margin="0,0,8,0"
                              VerticalAlignment="Bottom"
                              IsChecked="{Binding MonthlyRecord.IsPayrollPreviewDerivationVisible, Mode=TwoWay}"
                              IsEnabled="{Binding MonthlyRecord.HasPayrollPreviewDerivationGroups}"
                              Content="Herleitung anzeigen" />
                <Button Grid.Column="5"
                        MinWidth="148"
                        Margin="0,0,8,0"
                        VerticalAlignment="Bottom"
                        Classes="primary-action"
                        IsEnabled="{Binding CanExecutePayrollMonthAction}"
                        Click="OnFinalizePayrollMonthClick"
                        Content="{Binding PayrollMonthActionLabel}" />
                <Button Grid.Column="6"
                        VerticalAlignment="Bottom"
                        Classes="primary-action"
                        Command="{Binding CreatePayrollPdfCommand}"
                        Content="PDF erstellen" />
                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="7"
                            Margin="0,12,0,0"
                            Orientation="Horizontal"
                            Spacing="8"
                            IsVisible="{Binding MonthlyRecord.IsSubjectToWithholdingTax}">
                  <StackPanel Spacing="4" Width="120">
                    <TextBlock Classes="section-caption" Text="Quellensteuer %" />
                    <TextBox Text="{Binding MonthlyRecord.WithholdingTaxRatePercent, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Spacing="4" Width="150">
                    <TextBlock Classes="section-caption" Text="Korrektur" />
                    <TextBox Text="{Binding MonthlyRecord.WithholdingTaxCorrectionAmountChf, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Spacing="4" Width="260">
                    <TextBlock Classes="section-caption" Text="Korrekturtext" />
                    <TextBox Text="{Binding MonthlyRecord.WithholdingTaxCorrectionText, Mode=TwoWay}" />
                  </StackPanel>
                  <Button VerticalAlignment="Bottom"
                          Command="{Binding MonthlyRecord.ResetWithholdingTaxCommand}"
                          Content="Zuruecksetzen" />
                  <Button VerticalAlignment="Bottom"
                          Command="{Binding MonthlyRecord.SaveWithholdingTaxCommand}"
                          Content="Quellensteuer speichern" />
                </StackPanel>
              </Grid>
              <StackPanel Spacing="4" IsVisible="{Binding ShowReportingWorkspace}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Reporting" />
              </StackPanel>
              <StackPanel Spacing="4" IsVisible="{Binding ShowAnnualSalaryWorkspace}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding AnnualSalaryTitle}" />
                <TextBlock Foreground="#FF5F6B7A" Text="{Binding AnnualSalarySummary}" TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Spacing="4" IsVisible="{Binding ShowEmployeeWorkspace}">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding FormTitle}" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}" IsVisible="{Binding ShowTimeAndExpensesWorkspace}">
            <Grid RowDefinitions="Auto,*" MinHeight="0" DataContext="{Binding MonthlyRecord}">
              <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                <StackPanel Spacing="4">
                  <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding ContextTitle}" />
                  <TextBlock Foreground="#FF5F6B7A" Text="{Binding ContextDescription}" TextWrapping="Wrap" />
                  <TextBlock Classes="section-caption" Text="{Binding StatusSummary}" />
                  <TextBlock Classes="section-caption" Text="{Binding ContractSummary}" TextWrapping="Wrap" />
                  <TextBlock Classes="section-caption" Text="{Binding TotalsSummary}" TextWrapping="Wrap" />
                  <TextBlock Classes="section-caption" Text="{Binding ActionMessage}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <TabControl Grid.Row="1" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
                <TabItem Header="Zeiten">
                  <ScrollViewer MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="0,10,0,0">
                      <Grid ColumnDefinitions="1.25*,8,1.2*,8,*,8,*,8,*,8,*,8,*,8,*,8,*" RowDefinitions="Auto,Auto" HorizontalAlignment="Stretch">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Abrechnungsmonat" />
                          <controls:MonthPicker Text="{Binding SelectedMonthText, Mode=TwoWay}" Watermark="MM/YYYY" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Datum" />
                          <controls:AppDatePicker Text="{Binding TimeDate, Mode=TwoWay}" Watermark="DD.MM.YYYY" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Arbeitsstunden" />
                          <TextBox Text="{Binding HoursWorked, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="6" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Nachtstunden" />
                          <TextBox Text="{Binding NightHours, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="8" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Sonntagsstunden" />
                          <TextBox Text="{Binding SundayHours, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="10" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Feiertagsstunden" />
                          <TextBox Text="{Binding HolidayHours, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="12" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Pauschalzone 1" />
                          <TextBox Text="{Binding VehiclePauschalzone1, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="14" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Pauschalzone 2" />
                          <TextBox Text="{Binding VehiclePauschalzone2, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="16" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Regiezone 1" />
                          <TextBox Text="{Binding VehicleRegiezone1, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="17" Spacing="4">
                          <TextBlock Classes="section-caption" Text="Bemerkung" />
                          <TextBox Text="{Binding TimeNote, Mode=TwoWay}" />
                        </StackPanel>
                      </Grid>

                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding NewTimeEntryCommand}" Content="Neu" />
                        <Button Command="{Binding SaveTimeEntryCommand}" Content="Zeiteintrag speichern" />
                        <Button Command="{Binding DeleteTimeEntryCommand}" Content="Zeiteintrag loeschen" />
                      </StackPanel>

                      <TextBlock Classes="section-caption" Text="Tagesliste" />
                      <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" ClipToBounds="True">
                        <StackPanel Spacing="0">
                          <ItemsControl ItemsSource="{Binding TimeEntryColumns}" Background="#FFF8FAFC">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Width="{Binding Width}"
                                        BorderBrush="#FFD7E1EA"
                                        BorderThickness="0,0,1,1"
                                        Padding="{DynamicResource Theme.Layout.TableCellPadding}"
                                        DragDrop.AllowDrop="True"
                                        DragDrop.DragOver="OnTimeEntryColumnHeaderDragOver"
                                        DragDrop.Drop="OnTimeEntryColumnHeaderDrop"
                                        PointerPressed="OnTimeEntryColumnHeaderPointerPressed">
                                  <TextBlock FontWeight="SemiBold" Text="{Binding Header}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <ListBox Classes="table-list"
                                   ItemsSource="{Binding TimeEntryHistory}"
                                   SelectedItem="{Binding SelectedTimeEntry, Mode=TwoWay}"
                                   SelectionChanged="OnTimeEntryHistorySelectionChanged"
                                   MinHeight="240"
                                   BorderThickness="0">
                            <ListBox.ItemTemplate>
                              <DataTemplate>
                                <StackPanel Spacing="0">
                                  <ItemsControl ItemsSource="{Binding Cells}">
                                    <ItemsControl.ItemsPanel>
                                      <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                      </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <Border Width="{Binding Width}" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                                          <TextBlock FontWeight="SemiBold" Text="{Binding Value}" />
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}" IsVisible="{Binding HasNote}">
                                    <TextBlock Classes="section-caption" Text="{Binding Note}" TextWrapping="Wrap" />
                                  </Border>
                                </StackPanel>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

                <TabItem Header="Spesen">
                  <ScrollViewer MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" Margin="0,10,0,0">
                      <TextBlock Foreground="#FF5F6B7A" Text="Pro Mitarbeitendem und Monat wird im Spesenbereich nur noch das Total fuer Diverse Spesen gepflegt." TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="1.25*,8,1.2*,8,*,8,*,8,*,8,*,8,*,8,*,8,*" RowDefinitions="Auto" HorizontalAlignment="Stretch">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Abrechnungsmonat" />
                          <controls:MonthPicker Text="{Binding SelectedMonthText, Mode=TwoWay}" Watermark="MM/YYYY" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,0,10">
                          <TextBlock Classes="section-caption" Text="Spesen" />
                          <Grid>
                            <TextBox Padding="54,6,8,6" Text="{Binding ExpensesTotal, Mode=TwoWay}" />
                            <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" Text="{Binding DataContext.CurrencyPrefix, RelativeSource={RelativeSource AncestorType=Window}}" />
                          </Grid>
                        </StackPanel>
                      </Grid>

                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding ResetExpenseValuesCommand}" Content="Zuruecksetzen" />
                        <Button Command="{Binding SaveExpenseEntryCommand}" Content="Spesen speichern" />
                      </StackPanel>

                      <TextBlock Classes="section-caption" Text="Spesenliste" />
                      <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" ClipToBounds="True">
                        <StackPanel Spacing="0">
                          <Grid ColumnDefinitions="110,140" Background="#FFF8FAFC">
                            <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                              <TextBlock FontWeight="SemiBold" Text="Monat" />
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                              <TextBlock FontWeight="SemiBold" Text="Spesen" />
                            </Border>
                          </Grid>
                          <ListBox Classes="table-list"
                                   ItemsSource="{Binding ExpenseEntryHistory}"
                                   SelectedItem="{Binding SelectedExpenseEntry, Mode=TwoWay}"
                                   SelectionChanged="OnExpenseEntryHistorySelectionChanged"
                                   MinHeight="180"
                                   BorderThickness="0">
                            <ListBox.ItemTemplate>
                              <DataTemplate>
                                <Grid ColumnDefinitions="110,140">
                                  <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Month, StringFormat='{}{0:00}' }">
                                      <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:00}.{1}">
                                          <Binding Path="Month" />
                                          <Binding Path="Year" />
                                        </MultiBinding>
                                      </TextBlock.Text>
                                    </TextBlock>
                                  </Border>
                                  <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding ExpensesTotalChf, Converter={StaticResource ChfAmountConverter}}" />
                                  </Border>
                                </Grid>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

              </TabControl>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}" MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" IsVisible="{Binding ShowPayrollRunsWorkspace}">
            <Border Background="{DynamicResource Theme.Color.Surface}" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
              <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}" DataContext="{Binding MonthlyRecord}">
              <Grid ColumnDefinitions="*" RowDefinitions="Auto,Auto">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding PayrollPreviewTitle}" />
                <TextBlock Grid.Row="1" Foreground="#FF5F6B7A" Text="{Binding PayrollPreviewSummary}" TextWrapping="Wrap" />
              </Grid>

                <Border Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="0" IsVisible="{Binding ShowPayrollPreviewResultOnly}">
                  <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                    <Grid ColumnDefinitions="Auto,2.2*,1.1*,1.2*,1.1*" Margin="10,10,10,0">
                      <TextBlock Margin="0,0,8,0" FontWeight="SemiBold" Text="Tag" />
                      <TextBlock Grid.Column="1" Margin="0,0,8,0" FontWeight="SemiBold" Text="Position" />
                      <TextBlock Grid.Column="2" Margin="0,0,8,0" FontWeight="SemiBold" Text="Einheit / Menge" />
                      <TextBlock Grid.Column="3" Margin="0,0,8,0" FontWeight="SemiBold" Text="Ansatz / Regel" />
                      <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Betrag" TextAlignment="Right" HorizontalAlignment="Stretch" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding PayrollPreviewLines}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Spacing="0">
                            <Border Padding="10,8" BorderBrush="#FFE2E8F0" BorderThickness="0,0,0,1" IsVisible="{Binding IsRegular}">
                              <StackPanel Spacing="3">
                                <Grid ColumnDefinitions="Auto,2.2*,1.1*,1.2*,1.1*">
                                  <Border Background="{Binding ColorHint}" CornerRadius="999" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center" IsVisible="{Binding HasDisplayTag}">
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding DisplayTag}" />
                                  </Border>
                                  <TextBlock Grid.Column="1" Margin="0,0,8,0" Text="{Binding Label}" />
                                  <TextBlock Grid.Column="2" Margin="0,0,8,0" Text="{Binding QuantityDisplay}" />
                                  <TextBlock Grid.Column="3" Margin="0,0,8,0" Text="{Binding RateDisplay}" />
                                  <TextBlock Grid.Column="4" Text="{Binding AmountDisplay}" TextAlignment="Right" HorizontalAlignment="Stretch" />
                                </Grid>
                                <TextBlock Classes="section-caption" FontWeight="Normal" Margin="0,0,0,0" Text="{Binding Detail}" TextWrapping="Wrap" IsVisible="{Binding HasDetail}" />
                              </StackPanel>
                            </Border>

                            <Border Padding="10,8" Margin="0,4,0,4" Background="#FFEFF4F8" BorderBrush="#FFE2E8F0" BorderThickness="0,0,0,1" IsVisible="{Binding IsEmphasized}">
                              <StackPanel Spacing="3">
                                <Grid ColumnDefinitions="Auto,2.2*,1.1*,1.2*,1.1*">
                                  <Border Background="{Binding ColorHint}" CornerRadius="999" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center" IsVisible="{Binding HasDisplayTag}">
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding DisplayTag}" />
                                  </Border>
                                  <TextBlock Grid.Column="1" Margin="0,0,8,0" FontWeight="Bold" Text="{Binding Label}" />
                                  <TextBlock Grid.Column="2" Margin="0,0,8,0" Text="{Binding QuantityDisplay}" />
                                  <TextBlock Grid.Column="3" Margin="0,0,8,0" Text="{Binding RateDisplay}" />
                                  <TextBlock Grid.Column="4" FontWeight="Bold" Text="{Binding AmountDisplay}" TextAlignment="Right" HorizontalAlignment="Stretch" />
                                </Grid>
                                <TextBlock Classes="section-caption" FontWeight="Normal" Text="{Binding Detail}" TextWrapping="Wrap" IsVisible="{Binding HasDetail}" />
                              </StackPanel>
                            </Border>
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="0" IsVisible="{Binding ShowPayrollPreviewSplitView}">
                  <Grid ColumnDefinitions="*,8,2*" MinWidth="0">
                    <Border Grid.Column="0" Padding="0">
                      <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                        <Grid ColumnDefinitions="Auto,2.2*,1.1*,1.2*,1.1*" Margin="10,10,10,0">
                          <TextBlock Margin="0,0,8,0" FontWeight="SemiBold" Text="Tag" />
                          <TextBlock Grid.Column="1" Margin="0,0,8,0" FontWeight="SemiBold" Text="Position" />
                          <TextBlock Grid.Column="2" Margin="0,0,8,0" FontWeight="SemiBold" Text="Einheit / Menge" />
                          <TextBlock Grid.Column="3" Margin="0,0,8,0" FontWeight="SemiBold" Text="Ansatz / Regel" />
                          <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Betrag" TextAlignment="Right" HorizontalAlignment="Stretch" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding PayrollPreviewLines}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <StackPanel Spacing="0">
                                <Border Padding="10,8" BorderBrush="#FFE2E8F0" BorderThickness="0,0,0,1" IsVisible="{Binding IsRegular}">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="Auto,2.2*,1.1*,1.2*,1.1*">
                                      <Border Background="{Binding ColorHint}" CornerRadius="999" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center" IsVisible="{Binding HasDisplayTag}">
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding DisplayTag}" />
                                      </Border>
                                      <TextBlock Grid.Column="1" Margin="0,0,8,0" Text="{Binding Label}" />
                                      <TextBlock Grid.Column="2" Margin="0,0,8,0" Text="{Binding QuantityDisplay}" />
                                      <TextBlock Grid.Column="3" Margin="0,0,8,0" Text="{Binding RateDisplay}" />
                                      <TextBlock Grid.Column="4" Text="{Binding AmountDisplay}" TextAlignment="Right" HorizontalAlignment="Stretch" />
                                    </Grid>
                                    <TextBlock Classes="section-caption" FontWeight="Normal" Margin="0,0,0,0" Text="{Binding Detail}" TextWrapping="Wrap" IsVisible="{Binding HasDetail}" />
                                  </StackPanel>
                                </Border>

                                <Border Padding="10,8" Margin="0,4,0,4" Background="#FFEFF4F8" BorderBrush="#FFE2E8F0" BorderThickness="0,0,0,1" IsVisible="{Binding IsEmphasized}">
                                  <StackPanel Spacing="3">
                                    <Grid ColumnDefinitions="Auto,2.2*,1.1*,1.2*,1.1*">
                                      <Border Background="{Binding ColorHint}" CornerRadius="999" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center" IsVisible="{Binding HasDisplayTag}">
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding DisplayTag}" />
                                      </Border>
                                      <TextBlock Grid.Column="1" Margin="0,0,8,0" FontWeight="Bold" Text="{Binding Label}" />
                                      <TextBlock Grid.Column="2" Margin="0,0,8,0" Text="{Binding QuantityDisplay}" />
                                      <TextBlock Grid.Column="3" Margin="0,0,8,0" Text="{Binding RateDisplay}" />
                                      <TextBlock Grid.Column="4" FontWeight="Bold" Text="{Binding AmountDisplay}" TextAlignment="Right" HorizontalAlignment="Stretch" />
                                    </Grid>
                                    <TextBlock Classes="section-caption" FontWeight="Normal" Text="{Binding Detail}" TextWrapping="Wrap" IsVisible="{Binding HasDetail}" />
                                  </StackPanel>
                                </Border>
                              </StackPanel>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Background="#FFE2E8F0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext" />

                    <Border Grid.Column="2" Padding="0" BorderBrush="#FFE2E8F0" BorderThickness="1,0,0,0">
                      <StackPanel Spacing="0">
                        <TextBlock FontWeight="SemiBold" Margin="12,12,12,8" Text="Herleitung / Rechenschritte" />
                        <ItemsControl ItemsSource="{Binding PayrollPreviewDerivationGroups}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Expander HorizontalAlignment="Stretch"
                                        Tag="{Binding Title}"
                                        Initialized="OnPayrollPreviewDerivationGroupInitialized"
                                        IsVisible="{Binding HasItems}">
                                <Expander.Header>
                                  <TextBlock Classes="section-caption" FontWeight="SemiBold" Text="{Binding Title}" />
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Items}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      <Border Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="0,0,0,1" CornerRadius="0" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                                        <StackPanel Spacing="4">
                                          <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                            <Border Background="{Binding ColorHint}" CornerRadius="999" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center" IsVisible="{Binding HasDisplayTag}">
                                              <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding DisplayTag}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Classes="section-caption" Margin="0,0,8,0" FontWeight="SemiBold" Text="{Binding KindLabel}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Margin="0,0,8,0" FontWeight="SemiBold" Text="{Binding Label}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="{Binding ValueDisplay}" TextAlignment="Right" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                          </Grid>
                                          <TextBlock Classes="section-caption" FontWeight="Normal" Text="{Binding FormulaDisplay}" TextWrapping="Wrap" IsVisible="{Binding HasFormula}" />
                                          <TextBlock Classes="section-caption" FontWeight="Normal" Text="{Binding Detail}" TextWrapping="Wrap" IsVisible="{Binding HasDetail}" />
                                        </StackPanel>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </Expander>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding PayrollPreviewNotes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                        <TextBlock Foreground="#FF5F6B7A" Text="{Binding}" TextWrapping="Wrap" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </ScrollViewer>

          <ScrollViewer Grid.Row="1" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}" MinHeight="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" IsVisible="{Binding ShowAnnualSalaryWorkspace}">
            <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
              <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                <Grid ColumnDefinitions="Auto,*">
                  <Grid ColumnDefinitions="120,Auto,Auto" HorizontalAlignment="Left">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="section-caption" Text="Jahr" />
                      <TextBox Text="{Binding AnnualSalaryYear, Mode=TwoWay}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Margin="8,22,0,0"
                            VerticalAlignment="Top"
                            Command="{Binding LoadAnnualSalaryCommand}"
                            Content="Aktualisieren" />
                    <Button Grid.Column="2"
                            Margin="8,22,0,0"
                            VerticalAlignment="Top"
                            Command="{Binding CreateSalaryCertificatePdfCommand}"
                            Click="OnCreateSalaryCertificatePdfClick"
                            Content="Lohnausweis erstellen" />
                  </Grid>
                  <TextBlock Grid.Column="1"
                             Margin="12,26,0,0"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Foreground="#FF5F6B7A"
                             Text="{Binding SalaryCertificateCreatedDisplay}"
                             TextAlignment="Right" />
                </Grid>

                <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" ClipToBounds="True">
                  <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="72,94,122,108,96,132,156,132,96,96,96,122" Background="#FFF8FAFC">
                      <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Monat" /></Border>
                      <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Status" /></Border>
                      <Border Grid.Column="2" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Bruttolohn" TextAlignment="Right" /></Border>
                      <Border Grid.Column="3" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="AHV/IV/EO" TextAlignment="Right" /></Border>
                      <Border Grid.Column="4" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="ALV" TextAlignment="Right" /></Border>
                      <Border Grid.Column="5" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Krankentaggeld" TextAlignment="Right" /></Border>
                      <Border Grid.Column="6" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Aus-/Weiterbildung" TextAlignment="Right" /></Border>
                      <Border Grid.Column="7" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Total Sozialabzuege" TextAlignment="Right" /></Border>
                      <Border Grid.Column="8" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="BVG" TextAlignment="Right" /></Border>
                      <Border Grid.Column="9" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="QST" TextAlignment="Right" /></Border>
                      <Border Grid.Column="10" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Spesen" TextAlignment="Right" /></Border>
                      <Border Grid.Column="11" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Nettolohn" TextAlignment="Right" /></Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding AnnualSalaryMonths}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="72,94,122,108,96,132,156,132,96,96,96,122">
                            <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding MonthLabel}" /></Border>
                            <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Classes="payroll-status" Classes.payroll-status-finalized="{Binding IsStatusFinalized}" Classes.payroll-status-cancelled="{Binding IsStatusCancelled}" Classes.payroll-status-open-with-data="{Binding IsStatusOpenWithRecordedData}" Classes.payroll-status-open="{Binding IsStatusOpen}" Text="{Binding StatusDisplay}" /></Border>
                            <Border Grid.Column="2" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding GrossSalaryChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                            <Border Grid.Column="3" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding AhvIvEoDeductionChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                            <Border Grid.Column="4" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding AlvDeductionChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                            <Border Grid.Column="5" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding SicknessDailyAllowanceDeductionChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                            <Border Grid.Column="6" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding TrainingAndEducationDeductionChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                            <Border Grid.Column="7" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="{Binding TotalSocialDeductionChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                            <Border Grid.Column="8" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding BvgDeductionChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                            <Border Grid.Column="9" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding WithholdingTaxChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                            <Border Grid.Column="10" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding ExpensesChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                            <Border Grid.Column="11" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="{Binding NetSalaryChf, Converter={StaticResource ChfAmountConverter}}" TextAlignment="Right" /></Border>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                  <Grid ColumnDefinitions="*,*,*,*,*,*" RowDefinitions="Auto,Auto">
                    <TextBlock Classes="section-caption" Text="Bruttolohn total" />
                    <TextBlock Grid.Column="1" Classes="section-caption" Text="Sozialabzuege" />
                    <TextBlock Grid.Column="2" Classes="section-caption" Text="BVG" />
                    <TextBlock Grid.Column="3" Classes="section-caption" Text="Quellensteuer" />
                    <TextBlock Grid.Column="4" Classes="section-caption" Text="Spesen" />
                    <TextBlock Grid.Column="5" Classes="section-caption" Text="Nettolohn total" />
                    <TextBlock Grid.Row="1" FontWeight="SemiBold" Text="{Binding AnnualSalaryTotals.GrossSalaryChf, Converter={StaticResource ChfAmountConverter}}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" Text="{Binding AnnualSalaryTotals.SocialInsuranceDeductionChf, Converter={StaticResource ChfAmountConverter}}" />
                    <TextBlock Grid.Row="1" Grid.Column="2" FontWeight="SemiBold" Text="{Binding AnnualSalaryTotals.BvgDeductionChf, Converter={StaticResource ChfAmountConverter}}" />
                    <TextBlock Grid.Row="1" Grid.Column="3" FontWeight="SemiBold" Text="{Binding AnnualSalaryTotals.WithholdingTaxChf, Converter={StaticResource ChfAmountConverter}}" />
                    <TextBlock Grid.Row="1" Grid.Column="4" FontWeight="SemiBold" Text="{Binding AnnualSalaryTotals.ExpensesChf, Converter={StaticResource ChfAmountConverter}}" />
                    <TextBlock Grid.Row="1" Grid.Column="5" FontWeight="SemiBold" Text="{Binding AnnualSalaryTotals.NetSalaryChf, Converter={StaticResource ChfAmountConverter}}" />
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
          </ScrollViewer>

          <ScrollViewer Grid.Row="1" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}" MinHeight="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" IsVisible="{Binding ShowReportingWorkspace}">
            <Border Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
              <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
                <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto" HorizontalAlignment="Left">
                  <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0">
                    <TextBlock Classes="section-caption" Text="Abrechnungsmonat" />
                    <TextBox Width="118" IsReadOnly="True" Text="{Binding MonthCaptureMonthLabel}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4" Width="220">
                    <TextBlock Classes="section-caption" Text="Filter" />
                    <ComboBox ItemsSource="{Binding MonthCaptureFilters}" SelectedItem="{Binding SelectedMonthCaptureFilter, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>

                <TextBlock Classes="section-caption" Text="{Binding MonthCaptureSummary}" TextWrapping="Wrap" />

                <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" ClipToBounds="True">
                  <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="82,120,120,70,70,70,78,78,78,160,66" Background="#FFF8FAFC">
                      <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="PNr" /></Border>
                      <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Vorname" /></Border>
                      <Border Grid.Column="2" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Nachname" /></Border>
                      <Border Grid.Column="3" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Status" /></Border>
                      <Border Grid.Column="4" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Erfasst" /></Border>
                      <Border Grid.Column="5" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Arbeit" /></Border>
                      <Border Grid.Column="6" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Nacht" /></Border>
                      <Border Grid.Column="7" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Sonntag" /></Border>
                      <Border Grid.Column="8" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Feiertag" /></Border>
                      <Border Grid.Column="9" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Fahrzeug" /></Border>
                      <Border Grid.Column="10" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Einträge" /></Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding MonthCaptureOverviewRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="82,120,120,70,70,70,78,78,78,160,66">
                            <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding PersonnelNumber}" /></Border>
                            <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding FirstName}" /></Border>
                            <Border Grid.Column="2" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding LastName}" /></Border>
                            <Border Grid.Column="3" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding StatusDisplay}" /></Border>
                            <Border Grid.Column="4" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding CaptureDisplay}" /></Border>
                            <Border Grid.Column="5" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding HoursWorked, StringFormat='{}{0:0.##} h'}" /></Border>
                            <Border Grid.Column="6" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding NightHours, StringFormat='{}{0:0.##}'}" /></Border>
                            <Border Grid.Column="7" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding SundayHours, StringFormat='{}{0:0.##}'}" /></Border>
                            <Border Grid.Column="8" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding HolidayHours, StringFormat='{}{0:0.##}'}" /></Border>
                            <Border Grid.Column="9" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                              <TextBlock>
                                <TextBlock.Text>
                                  <MultiBinding StringFormat="P1 {0:0.##} | P2 {1:0.##} | R1 {2:0.##}">
                                    <Binding Path="VehiclePauschalzone1" />
                                    <Binding Path="VehiclePauschalzone2" />
                                    <Binding Path="VehicleRegiezone1" />
                                  </MultiBinding>
                                </TextBlock.Text>
                              </TextBlock>
                            </Border>
                            <Border Grid.Column="10" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding TimeEntryCount}" /></Border>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </ScrollViewer>

          <ScrollViewer Grid.Row="1" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}" MinHeight="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" IsVisible="{Binding ShowEmployeeWorkspace}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*">
              <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Classes="section-caption" Text="Stammdaten" />

              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Personalnummer" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding PersonnelNumber, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Vorname" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding FirstName, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="4" Margin="0,10,0,0">
                <TextBlock Classes="section-caption" Text="Nachname" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding LastName, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Geburtsdatum" />
                <controls:AppDatePicker IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding BirthDate, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Eintrittsdatum" />
                <controls:AppDatePicker IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding EntryDate, Mode=TwoWay}" />
              </StackPanel>

              <Grid Grid.Row="4" Grid.Column="0" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" Margin="0,10,6,0">
                <TextBlock Grid.ColumnSpan="2" Classes="section-caption" Text="Austrittsdatum" />
                <controls:AppDatePicker Grid.Row="1" IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding ExitDate, Mode=TwoWay}" />
                <Button Grid.Row="1" Grid.Column="1" Margin="8,0,0,0" Command="{Binding ClearExitDateCommand}" Content="Leeren" IsEnabled="{Binding CanClearExitDate}" VerticalAlignment="Bottom" />
              </Grid>
              <StackPanel Grid.Row="4" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Status" />
                <CheckBox IsChecked="{Binding IsActiveEmployee, Mode=TwoWay}" IsEnabled="{Binding CanEditFields}" Content="Aktiv" />
              </StackPanel>

              <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Classes="section-caption" Margin="0,8,0,0" Text="Zuordnung" />

              <StackPanel Grid.Row="6" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Abteilung" />
                <ComboBox IsEnabled="{Binding CanEditFields}" ItemsSource="{Binding DepartmentOptions}" SelectedItem="{Binding SelectedDepartmentOption, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Row="6" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Anstellungskategorie" />
                <ComboBox IsEnabled="{Binding CanEditFields}" ItemsSource="{Binding EmploymentCategoryOptions}" SelectedItem="{Binding SelectedEmploymentCategoryOption, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Spacing="4" Margin="0,10,0,0">
                <TextBlock Classes="section-caption" Text="Anstellungsort" />
                <ComboBox IsEnabled="{Binding CanEditFields}" ItemsSource="{Binding EmploymentLocationOptions}" SelectedItem="{Binding SelectedEmploymentLocationOption, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Classes="section-caption" Margin="0,8,0,0" Text="Adresse und Kontakt" />

              <StackPanel Grid.Row="9" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Strasse" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Street, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="9" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Hausnummer" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding HouseNumber, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Spacing="4" Margin="0,10,0,0">
                <TextBlock Classes="section-caption" Text="Adresszusatz" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding AddressLine2, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="11" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Postleitzahl" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding PostalCode, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="11" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Ort" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding City, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="12" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Land" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Country, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="12" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Wohnsitzland" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding ResidenceCountry, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="13" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Telefon" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding PhoneNumber, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="13" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="E-Mail" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Email, Mode=TwoWay}" />
              </StackPanel>

              <TextBlock Grid.Row="14" Grid.ColumnSpan="2" Classes="section-caption" Margin="0,8,0,0" Text="Payroll-relevante Stammdaten" />

              <StackPanel Grid.Row="15" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Nationalitaet" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Nationality, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="15" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Bewilligung" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding PermitCode, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="16" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Steuerstatus" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding TaxStatus, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="16" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Quellensteuerpflicht" />
                <ComboBox IsEnabled="{Binding CanEditFields}" ItemsSource="{Binding WithholdingTaxOptions}" SelectedItem="{Binding SelectedWithholdingTaxOption, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="17" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="AHV-Nummer" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding AhvNumber, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="17" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="IBAN" />
                <TextBox IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding Iban, Mode=TwoWay}" />
              </StackPanel>

              <TextBlock Grid.Row="18" Grid.ColumnSpan="2" Classes="section-caption" Margin="0,8,0,0" Text="Vertragsdaten" />

              <StackPanel Grid.Row="19" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Gueltig ab" />
                <controls:AppDatePicker IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding ContractValidFrom, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="19" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Gueltig bis" />
                <controls:AppDatePicker IsEnabled="{Binding CanEditFields}" SelectedDate="{Binding ContractValidTo, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Grid.Row="20" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Lohnart" />
                <ComboBox IsEnabled="{Binding CanEditFields}" ItemsSource="{Binding WageTypeOptions}" SelectedItem="{Binding SelectedWageType, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Row="20" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Stundenlohn" />
                <Grid>
                  <TextBox Padding="54,6,8,6" IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding HourlyRateChf, Mode=TwoWay}" />
                  <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" Text="{Binding CurrencyPrefix}" />
                </Grid>
              </StackPanel>

              <StackPanel Grid.Row="21" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="BVG pro Monat" />
                <Grid>
                  <TextBox Padding="54,6,8,6" IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding MonthlyBvgDeductionChf, Mode=TwoWay}" />
                  <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" Text="{Binding CurrencyPrefix}" />
                </Grid>
              </StackPanel>
              <StackPanel Grid.Row="21" Grid.Column="1" Spacing="4" Margin="6,10,0,0">
                <TextBlock Classes="section-caption" Text="Monatslohn" />
                <Grid>
                  <TextBox Padding="54,6,8,6" IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding MonthlySalaryAmountChf, Mode=TwoWay}" />
                  <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" Text="{Binding CurrencyPrefix}" />
                </Grid>
              </StackPanel>

              <StackPanel Grid.Row="22" Grid.Column="0" Spacing="4" Margin="0,10,6,0">
                <TextBlock Classes="section-caption" Text="Spezialzuschlag gemaess Vertrag" />
                <Grid>
                  <TextBox Padding="54,6,8,6" IsReadOnly="{Binding AreFieldsReadOnly}" Text="{Binding SpecialSupplementRateChf, Mode=TwoWay}" />
                  <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" Text="{Binding CurrencyPrefix}" />
                </Grid>
              </StackPanel>

              <Grid Grid.Row="23" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                <TextBlock Classes="section-caption" Text="Zuschlagssaetze" />
                <Button Grid.Column="1" Command="{Binding OpenContractVersionDialogCommand}" Content="Historie anzeigen" />
                <Button Grid.Column="2" Margin="10,0,0,0" Command="{Binding OpenNewContractVersionDialogCommand}" Content="Neuer Vertragsstand ab Monat" IsVisible="{Binding ShowEditActions}" />
              </Grid>
              <Border Grid.Row="24" Grid.ColumnSpan="2" Margin="0,10,0,0" Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                <TextBlock Foreground="#FF5F6B7A" Text="Nacht-, Sonntags- und Feiertagszuschlaege werden zentral im Bereich Einstellungen gepflegt und nicht mehr pro Mitarbeitendem." TextWrapping="Wrap" />
              </Border>
            </Grid>
          </ScrollViewer>

          <Border
              Grid.Row="3"
              Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}"
              Padding="{DynamicResource Theme.Layout.PanelPadding}"
              Background="#FFFFF1E6"
              BorderBrush="#FFF1C18A"
              BorderThickness="1"
              CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}"
              IsVisible="{Binding ShowDeleteConfirmation}">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock Foreground="#FF6B4A1F" Text="{Binding DeleteConfirmationText}" TextWrapping="Wrap" />
              <Button Grid.Column="1" Margin="10,0,0,0" Classes="danger-action" Command="{Binding ConfirmDeleteCommand}" Content="Archivieren" />
              <Button Grid.Column="2" Margin="10,0,0,0" Command="{Binding DismissDeleteCommand}" Content="Zurueck" />
            </Grid>
          </Border>

          <Border Grid.Row="4" Background="#FFF8FAFC" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}">
            <TextBlock Foreground="#FF304255" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
          </Border>

          <Grid Grid.Row="5" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="{DynamicResource Theme.Layout.SectionSpacing.TopMargin}" IsVisible="{Binding ShowEmployeeWorkspace}">
            <Button Grid.Column="0" Command="{Binding NewEmployeeCommand}" Content="Neu" />
            <Button Grid.Column="1" Margin="10,0,0,0" Command="{Binding EditEmployeeCommand}" Content="Bearbeiten" IsVisible="{Binding ShowViewActions}" />
            <Button Grid.Column="2" Margin="10,0,0,0" Command="{Binding DeleteCommand}" Content="Loeschen" IsVisible="{Binding ShowEditActions}" />
            <Button Grid.Column="4" Margin="10,0,0,0" Command="{Binding CancelCommand}" Content="Abbrechen" IsVisible="{Binding ShowEditActions}" />
            <Button Grid.Column="5" Classes="primary-action" Command="{Binding SaveCommand}" Content="Speichern" IsVisible="{Binding ShowEditActions}" />
          </Grid>

        </Grid>
      </Border>

      <Border
          Grid.Column="1"
          Background="#660F172A"
          Padding="24"
          IsVisible="{Binding ShowContractVersionDialog}">
        <Border
            MaxWidth="1040"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Padding="14"
            Background="#FFF8FAFC"
            BorderBrush="#FFD7E1EA"
            BorderThickness="1"
            CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}">
          <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding ContractVersionDialogTitle}" />
            <TextBlock Foreground="#FF5F6B7A" Text="{Binding ContractVersionDialogDescription}" TextWrapping="Wrap" />

            <StackPanel Spacing="8">
              <TextBlock Classes="section-caption" Text="Bisherige Historie" />
              <Border BorderBrush="#FFD7E1EA" BorderThickness="1,1,1,0" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Background="#FFF8FAFC">
                <Grid ColumnDefinitions="150,150,150,*,120">
                  <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Gueltig ab" /></Border>
                  <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Gueltig bis" /></Border>
                  <Border Grid.Column="2" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Stundenlohn" /></Border>
                  <Border Grid.Column="3" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="BVG / Spezial" /></Border>
                  <Border Grid.Column="4" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Status" /></Border>
                </Grid>
              </Border>
              <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" ClipToBounds="True">
                <ListBox Classes="table-list" ItemsSource="{Binding ContractHistory}" SelectedItem="{Binding SelectedContractHistoryEntry, Mode=TwoWay}" MinHeight="120">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="150,150,150,*,120">
                        <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding ValidFromDisplay}" /></Border>
                        <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding ValidToDisplay}" /></Border>
                        <Border Grid.Column="2" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding HourlyRateDisplay}" /></Border>
                        <Border Grid.Column="3" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding CompactSummary}" TextWrapping="Wrap" /></Border>
                        <Border Grid.Column="4" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                          <Border Background="{Binding StatusBadgeBackground}" CornerRadius="999" Padding="8,2" IsVisible="{Binding HasStatusBadge}" HorizontalAlignment="Left">
                            <TextBlock Classes="section-caption" Foreground="{Binding StatusBadgeForeground}" Text="{Binding StatusBadgeText}" />
                          </Border>
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>
            </StackPanel>

            <Grid ColumnDefinitions="150,150,*" IsVisible="{Binding ShowContractVersionCreateSection}">
              <StackPanel Spacing="4" Width="138">
                <TextBlock Classes="section-caption" Text="Neuer Stand gueltig ab" />
                <controls:AppDatePicker SelectedDate="{Binding NewContractVersionValidFrom, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="4" Width="138">
                <TextBlock Classes="section-caption" Text="Gueltig bis" />
                <controls:AppDatePicker SelectedDate="{Binding NewContractVersionValidTo, Mode=TwoWay}" />
              </StackPanel>
              <Border Grid.Column="2" Margin="12,20,0,0" Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                <TextBlock Foreground="#FF304255" Text="{Binding ContractVersionDialogSummary}" TextWrapping="Wrap" />
              </Border>
            </Grid>

            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock Foreground="#FF5F6B7A"
                         VerticalAlignment="Center"
                         Text="Beim Speichern endet der bisher aktive Stand automatisch am Vortag des neuen Datums."
                         IsVisible="{Binding ShowContractVersionCreateSection}"
                         TextWrapping="Wrap" />
              <Button Grid.Column="1" Margin="10,0,0,0" Command="{Binding DismissContractVersionDialogCommand}" Content="Schliessen" />
              <Button Grid.Column="2" Margin="10,0,0,0" Classes="primary-action" Command="{Binding ConfirmContractVersionDialogCommand}" Content="Neuen Stand speichern" IsVisible="{Binding ShowContractVersionCreateSection}" />
            </Grid>
          </StackPanel>
        </Border>
      </Border>

      <Border
          Grid.Column="1"
          Background="#660F172A"
          Padding="24"
          IsVisible="{Binding ShowSettingsVersionDialog}">
        <Border
            MaxWidth="1040"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Padding="14"
            Background="#FFF8FAFC"
            BorderBrush="#FFD7E1EA"
            BorderThickness="1"
            CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}">
          <StackPanel Spacing="{DynamicResource Theme.Layout.SectionSpacing}">
            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding SettingsVersionDialogTitle}" />
            <TextBlock Foreground="#FF5F6B7A" Text="{Binding SettingsVersionDialogDescription}" TextWrapping="Wrap" />

            <StackPanel Spacing="8">
              <TextBlock Classes="section-caption" Text="Bisherige Historie" />
              <Border BorderBrush="#FFD7E1EA" BorderThickness="1,1,1,0" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Background="#FFF8FAFC">
                <Grid ColumnDefinitions="150,150,*,140">
                  <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Gueltig ab" /></Border>
                  <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Gueltig bis" /></Border>
                  <Border Grid.Column="2" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Berechnungssaetze" /></Border>
                  <Border Grid.Column="3" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock FontWeight="SemiBold" Text="Status" /></Border>
                </Grid>
              </Border>
              <Border BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" ClipToBounds="True">
                <ListBox Classes="table-list" ItemsSource="{Binding SettingsVersionHistory}" SelectedItem="{Binding SelectedSettingsVersionHistoryEntry, Mode=TwoWay}" MinHeight="120">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="150,150,*,140">
                        <Border BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding ValidFromDisplay}" /></Border>
                        <Border Grid.Column="1" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding ValidToDisplay}" /></Border>
                        <Border Grid.Column="2" BorderBrush="#FFD7E1EA" BorderThickness="0,0,1,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}"><TextBlock Text="{Binding Summary}" TextWrapping="Wrap" /></Border>
                        <Border Grid.Column="3" BorderBrush="#FFD7E1EA" BorderThickness="0,0,0,1" Padding="{DynamicResource Theme.Layout.TableCellPadding}">
                          <Border Background="#FFE4F6EA" CornerRadius="999" Padding="8,2" IsVisible="{Binding ShowCurrentBadge}" HorizontalAlignment="Left">
                            <TextBlock Classes="section-caption" Foreground="#FF1F7A3D" Text="{Binding StatusDisplay}" />
                          </Border>
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>
            </StackPanel>

            <Grid ColumnDefinitions="150,150,*" IsVisible="{Binding ShowSettingsVersionCreateSection}">
              <StackPanel Spacing="4" Width="138">
                <TextBlock Classes="section-caption" Text="Neuer Stand gueltig ab" />
                <controls:AppDatePicker SelectedDate="{Binding NewSettingsVersionValidFrom, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="4" Width="138">
                <TextBlock Classes="section-caption" Text="Gueltig bis" />
                <controls:AppDatePicker SelectedDate="{Binding NewSettingsVersionValidTo, Mode=TwoWay}" />
              </StackPanel>
              <Border Grid.Column="2" Margin="12,20,0,0" Background="#FFFFFFFF" BorderBrush="#FFD7E1EA" BorderThickness="1" CornerRadius="{DynamicResource Theme.Layout.PanelCornerRadius}" Padding="{DynamicResource Theme.Layout.PanelPadding}">
                <TextBlock Foreground="#FF304255" Text="{Binding SettingsVersionDialogSummary}" TextWrapping="Wrap" />
              </Border>
            </Grid>

            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock Foreground="#FF5F6B7A"
                         VerticalAlignment="Center"
                         Text="Beim Speichern endet der bisher aktive Stand automatisch am Vortag des neuen Datums."
                         IsVisible="{Binding ShowSettingsVersionCreateSection}"
                         TextWrapping="Wrap" />
              <Button Grid.Column="1" Margin="10,0,0,0" Command="{Binding DismissSettingsVersionDialogCommand}" Content="Schliessen" />
              <Button Grid.Column="2" Margin="10,0,0,0" Classes="primary-action" Command="{Binding ConfirmSettingsVersionDialogCommand}" Content="Neuen Stand speichern" IsVisible="{Binding ShowSettingsVersionCreateSection}" />
            </Grid>
          </StackPanel>
        </Border>
      </Border>
    </Grid>

    <TextBlock Grid.Row="3" Foreground="#FF5F6B7A" Text="{Binding WorkspaceLabel}" />
  </Grid>
</Window>
